{
  "compilerOptions": {
    "module": "es2020",
    "allowJs": true,
    "target": "es2020",
    "lib": ["es2020", "DOM"],
    "typeRoots": ["node_modules/@types"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "rootDir": ".",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*.ts", "src/**/icon-names.js"]
}
