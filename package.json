{
  "name": "elements-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": "22.13.1"
  },
  "scripts": {
    "ci": "wireit",
    "ci:all": "PAGES_BASE_URL=/elements/ pnpm run ci && PAGES_BASE_URL=/elements/ node ./projects/internals/gitlab/cache-validate.js ci",
    "ci:reset": "pnpm run clean && pnpm i --frozen-lockfile --prefer-offline",
    "lighthouse": "wireit",
    "clean": "git clean -dfX",
    "format": "wireit",
    "format:fix": "wireit",
    "playwright": "wireit",
    "prepare": "wireit",
    "release": "wireit",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "@nvidia-elements/code": "workspace:*",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/core-react": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "12.0.0",
    "@semantic-release/exec": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/gitlab": "13.2.1",
    "@semantic-release/npm": "12.0.0",
    "@semantic-release/release-notes-generator": "13.0.0",
    "@tsconfig/node20": "20.1.4",
    "@weiran.zsd/multi-eslint-rule-config": "0.0.6",
    "commitlint": "19.5.0",
    "glob": "catalog:",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "playwright": "catalog:",
    "prettier": "3.4.2",
    "proper-lockfile": "4.1.2",
    "semantic-release": "22.0.12",
    "semantic-release-monorepo": "8.0.2",
    "semantic-release-replace-plugin": "1.2.7",
    "wireit": "0.14.11"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "format",
        "./projects/elements:ci",
        "./projects/elements-react:ci",
        "./projects/labs/behaviors-alpine:ci",
        "./projects/labs/brand:ci",
        "./projects/labs/cli:ci",
        "./projects/labs/code:ci",
        "./projects/labs/forms:ci",
        "./projects/labs/playwright-screencast:ci",
        "./projects/labs/snippets:ci",
        "./projects/monaco:ci",
        "./projects/pages:ci",
        "./projects/site:ci",
        "./projects/starters:ci",
        "./projects/starters/angular:ci",
        "./projects/starters/bundles:ci",
        "./projects/starters/eleventy:ci",
        "./projects/starters/eleventy-ssr:ci",
        "./projects/starters/importmaps:ci",
        "./projects/starters/lit-library:ci",
        "./projects/starters/mpa:ci",
        "./projects/starters/nextjs:ci",
        "./projects/starters/react:ci",
        "./projects/starters/react-18:ci",
        "./projects/starters/scoped-registry:ci",
        "./projects/starters/solidjs:ci",
        "./projects/starters/typescript:ci",
        "./projects/starters/vue:ci",
        "./projects/styles:ci",
        "./projects/testing:ci",
        "./projects/themes:ci",
        "./projects/internals/metadata:ci",
        "./projects/internals/tools:ci"
      ],
      "files": []
    },
    "lighthouse": {
      "command": "node ./projects/internals/gitlab/metrics.lighthouse.js",
      "dependencies": [
        "./projects/styles:test:lighthouse",
        "./projects/themes:test:lighthouse",
        "./projects/elements:test:lighthouse",
        "./projects/labs/brand:test:lighthouse",
        "./projects/labs/code:test:lighthouse",
        "./projects/labs/forms:test:lighthouse",
        "./projects/monaco:test:lighthouse"
      ],
      "output": [
        ".metrics/metrics.txt"
      ],
      "env": {
        "NODE_ENV": "production"
      },
      "files": [
        "./projects/internals/gitlab/metrics.lighthouse.js"
      ]
    },
    "release": {
      "command": "echo 'Releasing...'",
      "dependencies": [
        "release:themes",
        "release:testing",
        "release:elements",
        "release:elements-react",
        "release:labs-behaviors-alpine",
        "release:labs-brand",
        "release:labs-code",
        "release:labs-forms",
        "release:monaco",
        "release:styles"
      ]
    },
    "release:themes": {
      "command": "cd projects/themes && HUSKY=0 pnpm exec semantic-release"
    },
    "release:testing": {
      "command": "cd projects/testing && HUSKY=0 pnpm exec semantic-release"
    },
    "release:elements": {
      "command": "cd projects/elements && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:themes",
        "release:labs-forms"
      ]
    },
    "release:elements-react": {
      "command": "cd projects/elements-react && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:elements"
      ]
    },
    "release:labs-behaviors-alpine": {
      "command": "cd projects/labs/behaviors-alpine && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:elements"
      ]
    },
    "release:labs-brand": {
      "command": "cd projects/labs/brand && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:themes"
      ]
    },
    "release:labs-cli": {
      "command": "cd projects/labs/cli && HUSKY=0 pnpm exec semantic-release"
    },
    "release:labs-code": {
      "command": "cd projects/labs/code && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:elements"
      ]
    },
    "release:labs-forms": {
      "command": "cd projects/labs/forms && HUSKY=0 pnpm exec semantic-release"
    },
    "release:monaco": {
      "command": "cd projects/monaco && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:elements",
        "release:themes",
        "release:labs-forms"
      ]
    },
    "release:styles": {
      "command": "cd projects/styles && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:themes"
      ]
    },
    "format": {
      "command": "prettier --config prettier.config.js --check .",
      "files": [
        "./**/*.md",
        "./**/*.js",
        "./**/*.ts",
        "./**/*.css",
        "./**/*.cjs",
        "./**/*.mjs",
        "./**/*.json",
        "!**/vite.*.ts.timestamp*",
        "!**/_site/**",
        "!**/dist/**",
        "!**/.wireit/**",
        "!**/.next/**",
        "!**/__screenshots__/**",
        "!**/coverage/**",
        "!**/node_modules/**",
        "!projects/elements/src/icon/{icons,server}.ts",
        "!projects/internals/metadata/static/**",
        "!projects/elements-react/src/**/*",
        "!projects/monaco/src/themes/generated/**",
        "!projects/**/src/vendor/**/*",
        "!projects/**/.screencast/.auth/*",
        "!projects/starters/nextjs/next-env.d.ts"
      ],
      "output": []
    },
    "format:fix": {
      "command": "prettier --config prettier.config.js --write .",
      "dependencies": [
        "./projects/elements:lint:fix",
        "./projects/internals/metadata:lint:fix",
        "./projects/internals/patterns:lint:fix",
        "./projects/internals/tools:lint:fix",
        "./projects/labs/behaviors-alpine:lint:fix",
        "./projects/labs/brand:lint:fix",
        "./projects/labs/cli:lint:fix",
        "./projects/labs/code:lint:fix",
        "./projects/labs/forms:lint:fix",
        "./projects/labs/playwright-screencast:lint:fix",
        "./projects/labs/snippets:lint:fix",
        "./projects/monaco:lint:fix",
        "./projects/site:lint:fix",
        "./projects/testing:lint:fix"
      ]
    },
    "playwright": {
      "command": "pnpm exec playwright install chromium --with-deps chromium"
    },
    "prepare": {
      "command": "test -n \"$CI\" || (pnpm run playwright & node .husky/install.mjs)"
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "lmdb",
      "msgpackr-extract",
      "msw"
    ],
    "onlyBuiltDependencies": [
      "@bundled-es-modules/glob",
      "esbuild",
      "sharp",
      "style-dictionary"
    ],
    "patchedDependencies": {
      "monaco-editor": "patches/monaco-editor.patch"
    }
  }
}
