{
  "name": "elements-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "packageManager": "pnpm@8.15.1",
  "engines": {
    "node": "20.11.0"
  },
  "scripts": {
    "ci": "wireit",
    "ci:nocache": "pnpm run clean && pnpm i && pnpm run ci",
    "format": "wireit",
    "format:fix": "wireit",
    "clean": "git clean -dfX",
    "playwright": "wireit",
    "prepare": "wireit",
    "release": "semantic-release",
    "commitlint": "commitlint --edit",
    "pnpm:devPreinstall": "! test -n \"$CI\" || pnpm config set store-dir .pnpm-store"
  },
  "devDependencies": {
    "@amanda-mitchell/semantic-release-npm-multiple": "3.9.0",
    "@semantic-release/changelog": "6.0.3",
    "@commitlint/cli": "18.4.3",
    "@commitlint/config-conventional": "18.4.3",
    "@semantic-release/commit-analyzer": "11.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/gitlab": "12.1.1",
    "@semantic-release/npm": "11.0.2",
    "@semantic-release/release-notes-generator": "12.1.0",
    "@tsconfig/node20": "20.1.2",
    "@types/node": "20.11.6",
    "commitlint": "18.4.3",
    "husky": "8.0.3",
    "playwright": "1.40.1",
    "prettier": "3.1.1",
    "semantic-release": "22.0.12",
    "semantic-release-replace-plugin": "1.2.7",
    "wireit": "0.14.3"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "./projects/pages:ci",
        "./projects/demos/angular:ci",
        "./projects/demos/buildless:ci",
        "./projects/demos/extensions:ci",
        "./projects/demos/mpa:ci",
        "./projects/demos/nextjs:ci",
        "./projects/demos/react:ci",
        "./projects/demos/typescript:ci",
        "./projects/elements:ci",
        "./projects/elements-react:ci"
      ]
    },
    "format": {
      "command": "prettier --config prettier.config.js --check .",
      "files": [
        "./**/*.md",
        "./**/*.js",
        "./**/*.ts",
        "./**/*.css",
        "./**/*.cjs",
        "./**/*.mjs",
        "./**/*.json"
      ],
      "output": []
    },
    "format:fix": {
      "command": "prettier --config prettier.config.js --write ."
    },
    "playwright": {
      "command": "pnpm exec playwright install chromium --with-deps chromium"
    },
    "prepare": {
      "command": "test -n \"$CI\" || (pnpm run playwright | husky install)"
    }
  }
}
