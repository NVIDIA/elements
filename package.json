{
  "name": "elements-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": "24.12.0"
  },
  "scripts": {
    "ci": "wireit",
    "ci:reset": "pnpm run clean && pnpm i --frozen-lockfile --prefer-offline",
    "lighthouse": "wireit",
    "clean": "git clean -dfX",
    "format": "wireit",
    "format:fix": "wireit",
    "playwright": "wireit",
    "prepare": "wireit",
    "release": "wireit",
    "commitlint": "commitlint --edit",
    "lint:vale": "wireit",
    "lint:vale:sync": "config/vale/bin/vale sync"
  },
  "devDependencies": {
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "12.0.0",
    "@semantic-release/exec": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "12.0.0",
    "@semantic-release/release-notes-generator": "13.0.0",
    "@weiran.zsd/multi-eslint-rule-config": "0.0.6",
    "commitlint": "19.5.0",
    "glob": "catalog:",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "playwright": "catalog:",
    "prettier": "3.4.2",
    "proper-lockfile": "4.1.2",
    "semantic-release": "22.0.12",
    "semantic-release-monorepo": "8.0.2",
    "semantic-release-replace-plugin": "1.2.7",
    "tar": "7.5.11",
    "unzipper": "0.12.3",
    "wireit": "0.14.12",
    "@semantic-release/github": "12.0.3"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "**/*.{ts,md}": "pnpm run lint:vale"
  },
  "wireit": {
    "ci": {
      "script": "pnpm run format && pnpm run lint:vale",
      "dependencies": [
        "./projects/elements:ci",
        "./projects/forms:ci",
        "./projects/lint:ci",
        "./projects/styles:ci",
        "./projects/internals/testing:ci",
        "./projects/themes:ci",
        "./projects/internals/metadata:ci"
      ],
      "files": []
    },
    "release": {
      "command": "echo 'Releasing...'",
      "dependencies": [
        "release:themes",
        "release:testing",
        "release:elements",
        "release:labs-behaviors-alpine",
        "release:labs-brand",
        "release:lint",
        "release:labs-forms",
        "release:styles"
      ]
    },
    "release:themes": {
      "command": "cd projects/themes && HUSKY=0 pnpm exec semantic-release"
    },
    "release:testing": {
      "command": "cd projects/internals/testing && HUSKY=0 pnpm exec semantic-release"
    },
    "release:elements": {
      "command": "cd projects/elements && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:themes",
        "release:labs-forms"
      ]
    },
    "release:labs-forms": {
      "command": "cd projects/forms && HUSKY=0 pnpm exec semantic-release"
    },
    "release:lint": {
      "command": "cd projects/lint && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:themes",
        "release:styles"
      ]
    },
    "release:styles": {
      "command": "cd projects/styles && HUSKY=0 pnpm exec semantic-release",
      "dependencies": [
        "release:themes"
      ]
    },
    "format": {
      "command": "prettier --config prettier.config.js --check --cache .",
      "files": [
        "./**/*.md",
        "./**/*.js",
        "./**/*.ts",
        "./**/*.css",
        "./**/*.cjs",
        "./**/*.mjs",
        "./**/*.json",
        "!**/vite.*.ts.timestamp*",
        "!**/_site/**",
        "!**/dist/**",
        "!**/.11ty-vite/**",
        "!**/.eslintcache/**",
        "!**/.wireit/**",
        "!**/.next/**",
        "!**/__screenshots__/**",
        "!**/coverage/**",
        "!**/node_modules/**",
        "!projects/elements/src/icon/{icons,server}.ts",
        "!projects/internals/metadata/static/**",
        "!projects/elements-react/src/**/*",
        "!projects/monaco/src/themes/generated/**",
        "!projects/**/src/vendor/**/*",
        "!projects/**/.screencast/.auth/*",
        "!projects/starters/nextjs/next-env.d.ts"
      ],
      "output": [
        "node_modules/.cache/prettier/**"
      ]
    },
    "format:fix": {
      "command": "prettier --config prettier.config.js --write ."
    },
    "lint:fix": {
      "command": "prettier --config prettier.config.js --write .",
      "dependencies": [
        "./projects/elements:lint:fix",
        "./projects/forms:lint:fix",
        "./projects/internals/metadata:lint:fix",
        "./projects/internals/testing:lint:fix",
        "./projects/lint:lint:fix"
      ]
    },
    "playwright": {
      "command": "pnpm exec playwright install chromium --with-deps chromium"
    },
    "prepare": {
      "command": "test -n \"$CI\" || (pnpm run playwright & node .husky/install.mjs) ; node config/vale/install.mjs"
    }
  },
  "pnpm": {
    "overrides": {
      "archiver>glob": "catalog:",
      "eslint": "catalog:"
    }
  }
}
