{
  "name": "@elements/elements",
  "version": "0.2.0",
  "type": "module",
  "customElements": "custom-elements.json",
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/polyfills/index.js",
    "./**/define.js"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./custom-elements.json": "./dist/custom-elements.json",
    "./assets/*": "./dist/assets/*",
    "./css/*": "./dist/css/*",
    ".": "./dist/index.js",
    "./internal": "./dist/internal/index.js",
    "./internal/index.js": "./dist/internal/index.js",
    "./test": "./dist/test/index.js",
    "./test/index.js": "./dist/test/index.js",
    "./polyfills": "./dist/polyfills/index.js",
    "./polyfills/index.js": "./dist/polyfills/index.js",
    "./button": "./dist/button/index.js",
    "./button/index.js": "./dist/button/index.js",
    "./button/define.js": "./dist/button/define.js",
    "./card": "./dist/card/index.js",
    "./card/index.js": "./dist/card/index.js",
    "./card/define.js": "./dist/card/define.js",
    "./icon": "./dist/icon/index.js",
    "./icon/index.js": "./dist/icon/index.js",
    "./icon/define.js": "./dist/icon/define.js",
    "./icon-button": "./dist/icon-button/index.js",
    "./icon-button/index.js": "./dist/icon-button/index.js",
    "./icon-button/define.js": "./dist/icon-button/define.js"
  },
  "typesVersions": {
    "*": {
      "*/define": [
        "dist/*/define.d.ts"
      ],
      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "pnpm run build && pnpm run build:watch & start-storybook -p 7789",
    "ci": "pnpm run build && pnpm run build-storybook && pnpm run test",
    "storybook": "start-storybook -p 7789",
    "build": "vite build",
    "build:watch": "vite build --mode watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch",
    "build-storybook": "build-storybook --output-dir ./storybook-static",
    "create-icon-spritesheet": "node create-icon-spritesheet.js",
    "prepublishonly": "pnpm run build",
    "generate-manifest": "cem analyze --litelement --globs src/**/*.ts --exclude **.stories.ts src/internal/**/*.ts"
  },
  "dependencies": {
    "lit": "^2.1",
    "lit-html": "^2.1"
  },
  "optionalDependencies": {
    "element-internals-polyfill": "^1.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/runtime": "^7.18.0",
    "@custom-elements-manifest/analyzer": "0.6.3",
    "@emotion/core": "10.3.0",
    "@emotion/react": "11.8.1",
    "@emotion/styled": "10.3.0",
    "@prettier/plugin-xml": "1.2.0",
    "@storybook/addon-backgrounds": "6.5.9",
    "@storybook/addon-docs": "6.5.9",
    "@storybook/addon-essentials": "6.5.9",
    "@storybook/addon-interactions": "6.5.9",
    "@storybook/addon-measure": "6.5.9",
    "@storybook/addon-outline": "6.5.9",
    "@storybook/addons": "6.5.9",
    "@storybook/api": "6.5.9",
    "@storybook/builder-vite": "0.1.37",
    "@storybook/client-api": "6.5.9",
    "@storybook/components": "6.5.9",
    "@storybook/core-common": "6.5.9",
    "@storybook/core-events": "6.5.9",
    "@storybook/node-logger": "6.5.9",
    "@storybook/store": "6.5.9",
    "@storybook/testing-library": "0.0.7",
    "@storybook/theming": "6.5.9",
    "@storybook/web-components": "6.5.9",
    "@types/react": "16.9.52",
    "@types/react-dom": "16.9.8",
    "@xmldom/xmldom": "0.8.0",
    "babel-loader": "^8.0.0",
    "bindings": "1.5.0",
    "happy-dom": "^5.2.0",
    "nan": "2.12.1",
    "postcss": "8.3.11",
    "postcss-mixins": "9.0.1",
    "postcss-nested": "5.0.6",
    "prettier": "2.5.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "rollup": "^2.70.2",
    "rollup-plugin-css-hmr": "0.2.1",
    "rollup-plugin-minify-html-literals": "1.2.6",
    "rollup-plugin-shell": "^1.0.3",
    "rollup-plugin-terser": "7.0.2",
    "storybook-addon-designs": "6.2.1",
    "svgo": "2.8.0",
    "typescript": "4.7.4",
    "vite": "^2.6.0",
    "vitest": "^0.15.2",
    "webpack": "^4.46.0"
  },
  "publishConfig": {
    "registry": "https://artifactory.build.nvidia.com/artifactory/api/npm/elements-ui-npm/"
  },
  "eslintConfig": {
    "parserOptions": {
      "sourceType": "module"
    }
  },
  "bzlgen": {
    "md5": "d7a7fdef8cb9350c507ecf742f9899fa"
  }
}
