{
  "name": "elements-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "packageManager": "pnpm@8.15.1",
  "engines": {
    "node": "20.11.0"
  },
  "scripts": {
    "ci": "pnpm run ci:validate && node ./projects/internals/gitlab/cache-validate.js",
    "ci:nocache": "pnpm run clean && pnpm i --frozen-lockfile --prefer-offline && pnpm run ci",
    "ci:validate": "wireit",
    "lighthouse": "wireit",
    "format": "wireit",
    "format:fix": "wireit",
    "clean": "git clean -dfX",
    "playwright": "wireit",
    "prepare": "wireit",
    "release": "wireit",
    "commitlint": "commitlint --edit",
    "gitlab:coverage": "wireit"
  },
  "devDependencies": {
    "@commitlint/cli": "19.2.1",
    "@commitlint/config-conventional": "19.1.0",
    "@elements/elements": "workspace:*",
    "@elements/elements-react": "workspace:*",
    "@nvidia-elements/core": "workspace:@elements/elements@*",
    "@nvidia-elements/core-react": "workspace:@elements/elements-react@*",
    "@nvidia-elements/themes": "workspace:*",
    "@nvidia-elements/code": "workspace:*",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "12.0.0",
    "@semantic-release/exec": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/gitlab": "13.0.3",
    "@semantic-release/npm": "12.0.0",
    "@semantic-release/release-notes-generator": "13.0.0",
    "@tsconfig/node20": "20.1.2",
    "@types/node": "20.11.6",
    "commitlint": "19.2.1",
    "glob": "10.3.10",
    "husky": "8.0.3",
    "lint-staged": "15.2.1",
    "playwright": "1.44.1",
    "prettier": "3.2.5",
    "semantic-release": "22.0.12",
    "semantic-release-monorepo": "8.0.2",
    "semantic-release-replace-plugin": "1.2.7",
    "wireit": "0.14.4"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "wireit": {
    "ci:validate": {
      "dependencies": [
        "./projects/elements:ci",
        "./projects/elements-react:ci",
        "./projects/labs/code:ci",
        "./projects/labs/behaviors-alpine:ci",
        "./projects/labs/testing-lighthouse:ci",
        "./projects/pages:ci",
        "./projects/starters/angular:ci",
        "./projects/starters/buildless:ci",
        "./projects/starters/lit-library:ci",
        "./projects/starters/mpa:ci",
        "./projects/starters/nextjs:ci",
        "./projects/starters/react:ci",
        "./projects/starters/scoped-registry:ci",
        "./projects/starters/solidjs:ci",
        "./projects/starters/typescript:ci",
        "./projects/storybook:ci",
        "./projects/testing:ci",
        "./projects/themes:ci",
        "lighthouse"
      ]
    },
    "lighthouse": {
      "command": "pnpm run -r test:lighthouse --workspace-concurrency=1",
      "files": [
        "projects/elments/src/**/*.test.lighthouse.ts",
        "projects/elments/vitest.lighthouse.html",
        "projects/elments/vitest.lighthouse.ts",
        "projects/elments/vitest.lighthouse.build.ts",
        "projects/labs/code/src/**/*.test.lighthouse.ts",
        "projects/labs/code/vitest.lighthouse.html",
        "projects/labs/code/vitest.lighthouse.ts",
        "projects/labs/code/vitest.lighthouse.build.ts"
      ],
      "output": [
        "projects/elements/.lighthouse",
        "projects/elements/coverage/lighthouse/**",
        "projects/labs/code/.lighthouse",
        "projects/labs/code/coverage/lighthouse/**"
      ],
      "env": {
        "NODE_ENV": "production",
        "LIGHTHOUSE_ALL": {
          "external": true
        }
      }
    },
    "release": {
      "command": "echo 'Releasing...'",
      "dependencies": [
        "release:themes",
        "release:testing",
        "release:elements",
        "release:elements-react",
        "release:labs-behaviors-alpine",
        "release:labs-code"
      ]
    },
    "release:themes": {
      "command": "cd projects/themes && pnpm exec semantic-release"
    },
    "release:testing": {
      "command": "cd projects/testing && pnpm exec semantic-release"
    },
    "release:elements": {
      "command": "cd projects/elements && pnpm exec semantic-release",
      "dependencies": [
        "release:themes"
      ]
    },
    "release:elements-react": {
      "command": "cd projects/elements-react && pnpm exec semantic-release",
      "dependencies": [
        "release:elements"
      ]
    },
    "release:labs-behaviors-alpine": {
      "command": "cd projects/labs/behaviors-alpine && pnpm exec semantic-release",
      "dependencies": [
        "release:elements"
      ]
    },
    "release:labs-code": {
      "command": "cd projects/labs/code && pnpm exec semantic-release",
      "dependencies": [
        "release:elements"
      ]
    },
    "format": {
      "command": "prettier --config prettier.config.js --check .",
      "files": [
        "./**/*.md",
        "./**/*.js",
        "./**/*.ts",
        "./**/*.css",
        "./**/*.cjs",
        "./**/*.mjs",
        "./**/*.json"
      ],
      "output": []
    },
    "format:fix": {
      "command": "prettier --config prettier.config.js --write ."
    },
    "playwright": {
      "command": "pnpm exec playwright install chromium --with-deps chromium"
    },
    "prepare": {
      "command": "test -n \"$CI\" || (pnpm run playwright & husky install)"
    },
    "gitlab:coverage": {
      "command": "node ./projects/internals/gitlab/index.js",
      "dependencies": []
    }
  }
}
