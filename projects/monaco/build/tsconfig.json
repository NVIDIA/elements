{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "resolveJsonModule": true,
    "strict": true,
    "baseUrl": "../",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@nvidia-elements/*": ["../*"]
    }
  },
  "include": ["./**/*.ts"]
}
