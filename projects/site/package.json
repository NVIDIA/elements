{
  "name": "site",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build"
      ]
    },
    "dev": {
      "dependencies": [
        "build:watch"
      ]
    },
    "build:watch": {
      "command": "pnpm exec eleventy --incremental --serve --port=8082",
      "service": true,
      "dependencies": [
        "../elements:build",
        "../styles:build",
        "../themes:build",
        "../labs/code:build",
        "../monaco:build",
        "../internals/patterns:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "pnpm exec eleventy",
      "files": [
        "src",
        "public",
        "./eleventy.config.js"
      ],
      "output": [
        "dist/**",
        ".11ty-vite"
      ],
      "dependencies": [
        "clean",
        "../elements:build",
        "../styles:build",
        "../themes:build",
        "../labs/code:build",
        "../monaco:build",
        "../internals/metadata:build",
        "../internals/patterns:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "preview": {
      "command": "pnpm run build && vite preview --base=$PAGES_BASE_URL",
      "service": true,
      "files": [
        "src",
        "public",
        "./eleventy.config.js"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/"
        }
      }
    },
    "clean": {
      "command": "rm -rf dist && rm -rf .11ty-vite",
      "files": [],
      "output": [],
      "dependencies": []
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.js",
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../internals/eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix"
    }
  },
  "dependencies": {
    "chart.js": "4.4.0",
    "lit": "catalog:"
  },
  "devDependencies": {
    "@11ty/eleventy": "catalog:",
    "@11ty/eleventy-plugin-vite": "catalog:",
    "@eslint/js": "catalog:",
    "@lit-labs/eleventy-plugin-lit": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "@internals/eslint": "workspace:*",
    "@internals/metadata": "workspace:*",
    "@internals/patterns": "workspace:*",
    "@nvidia-elements/code": "workspace:*",
    "@nvidia-elements/playwright-screencast": "workspace:*",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/monaco": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@sentry/browser": "catalog:",
    "compare-versions": "6.1.1",
    "fflate": "0.8.2",
    "eslint": "catalog:",
    "html-format": "1.1.7",
    "html-minifier": "4.0.0",
    "lightningcss": "1.30.0",
    "markdown-it": "catalog:",
    "markdown-it-link-attributes": "catalog:",
    "pagefind": "1.3.0",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
