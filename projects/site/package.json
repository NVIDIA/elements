{
  "name": "site",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "dev:fast": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "test:lighthouse": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "test:lighthouse"
      ]
    },
    "dev": {
      "command": "pnpm exec eleventy --incremental --serve --quiet --port=8082",
      "service": true,
      "dependencies": [
        "build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "dev:fast": {
      "command": "pnpm exec eleventy --serve --quiet --port=8082",
      "service": true,
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "pnpm exec eleventy",
      "files": [
        "../elements/dist/**/*.js",
        "../elements/dist/**/*.stories.json",
        "../styles/dist/**/*.css",
        "../styles/dist/**/*.stories.json",
        "../themes/dist/**/*.css",
        "../themes/dist/**/*.stories.json",
        "../themes/dist/**/*.json",
        "../labs/code/dist/**/*.js",
        "../labs/code/dist/**/*.stories.json",
        "../labs/forms/dist/**/*.js",
        "../labs/forms/dist/**/*.stories.json",
        "../labs/markdown/dist/**/*.js",
        "../labs/markdown/dist/**/*.stories.json",
        "../monaco/dist/**/*.js",
        "../monaco/dist/**/*.stories.json",
        "../internals/metadata/static/**",
        "../internals/patterns/dist/**/*.js",
        "../internals/patterns/dist/**/*.stories.json",
        "../internals/tools/dist/**/*.js",
        "../internals/tools/dist/**/*.stories.json",
        "src",
        "!src/**/*.test.lighthouse.ts",
        "public",
        "./eleventy.config.js"
      ],
      "output": [
        "dist/**",
        ".11ty-vite"
      ],
      "dependencies": [
        "clean",
        {
          "script": "../elements:build",
          "cascade": false
        },
        {
          "script": "../styles:build",
          "cascade": false
        },
        {
          "script": "../themes:build",
          "cascade": false
        },
        {
          "script": "../labs/code:build",
          "cascade": false
        },
        {
          "script": "../labs/forms:build",
          "cascade": false
        },
        {
          "script": "../labs/markdown:build",
          "cascade": false
        },
        {
          "script": "../monaco:build",
          "cascade": false
        },
        {
          "script": "../internals/metadata:build",
          "cascade": false
        },
        {
          "script": "../internals/patterns:build",
          "cascade": false
        },
        {
          "script": "../internals/tools:build",
          "cascade": false
        }
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "preview": {
      "command": "pnpm run build && vite preview --base=$PAGES_BASE_URL",
      "service": true,
      "files": [
        "src",
        "public",
        "./eleventy.config.js"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/"
        }
      }
    },
    "clean": {
      "command": "rm -rf dist && rm -rf .11ty-vite",
      "files": [],
      "output": [],
      "dependencies": []
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.js",
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../internals/eslint:ci",
        "../labs/lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../internals/eslint:ci",
        "../labs/lint:build"
      ]
    },
    "test:lighthouse": {
      "command": "playwright-lock 'vitest run --config=vitest.lighthouse.ts'",
      "files": [
        "src/index.test.lighthouse.ts",
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.ts"
      ],
      "output": [],
      "dependencies": [
        "build",
        "../internals/vite:ci"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "dependencies": {
    "chart.js": "4.4.0",
    "lit": "catalog:"
  },
  "devDependencies": {
    "@11ty/eleventy": "catalog:",
    "@11ty/eleventy-plugin-vite": "catalog:",
    "@eslint/js": "catalog:",
    "@lit-labs/eleventy-plugin-lit": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "@internals/eslint": "workspace:*",
    "@internals/metadata": "workspace:*",
    "@internals/tools": "workspace:*",
    "@internals/patterns": "workspace:*",
    "@internals/vite": "workspace:*",
    "@nvidia-elements/code": "workspace:*",
    "@nvidia-elements/forms": "workspace:*",
    "@nvidia-elements/lint": "workspace:*",
    "@nvidia-elements/markdown": "workspace:*",
    "@nvidia-elements/playwright-screencast": "workspace:*",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/monaco": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@sentry/browser": "catalog:",
    "compare-versions": "6.1.1",
    "eslint": "catalog:",
    "html-minifier": "4.0.0",
    "lighthouse": "catalog:",
    "lightningcss": "1.30.0",
    "markdown-it": "catalog:",
    "markdown-it-link-attributes": "catalog:",
    "pagefind": "1.3.0",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
