{
  "name": "pages",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "command": "echo 'building pages...'",
      "dependencies": [
        "pages:demos:angular",
        "pages:demos:angular-legacy",
        "pages:demos:buildless",
        "pages:demos:mpa",
        "pages:demos:react",
        "pages:demos:solidjs",
        "pages:demos:typescript",
        "pages:demos:vue",
        "pages:elements"
      ],
      "files": [],
      "output": []
    },
    "pages:demos:angular": {
      "command": "cp -a ../starters/angular/dist/angular-app/browser/. ./dist/starters/angular",
      "dependencies": [
        "../starters/angular:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/angular/**"
      ]
    },
    "pages:demos:angular-legacy": {
      "command": "cp -a ../starters/angular-legacy/dist/angular-app/. ./dist/starters/angular-legacy",
      "dependencies": [
        "../starters/angular-legacy:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/angular-legacy/**"
      ]
    },
    "pages:demos:buildless": {
      "command": "cp -a ../starters/buildless/dist/. ./dist/starters/buildless/",
      "dependencies": [
        "../starters/buildless:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/buildless/**"
      ]
    },
    "pages:demos:mpa": {
      "command": "cp -a ../starters/mpa/dist/. ./dist/starters/mpa",
      "dependencies": [
        "../starters/mpa:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/mpa/**"
      ]
    },
    "pages:demos:react": {
      "command": "cp -a ../starters/react/dist/. ./dist/starters/react",
      "dependencies": [
        "../starters/react:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/react/**"
      ]
    },
    "pages:demos:solidjs": {
      "command": "cp -a ../starters/solidjs/dist/. ./dist/starters/solidjs",
      "dependencies": [
        "../starters/solidjs:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/solidjs/**"
      ]
    },
    "pages:demos:typescript": {
      "command": "cp -a ../starters/typescript/dist/. ./dist/starters/typescript",
      "dependencies": [
        "../starters/typescript:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/typescript/**"
      ]
    },
    "pages:demos:vue": {
      "command": "cp -a ../starters/vue/dist/. ./dist/starters/vue",
      "dependencies": [
        "../starters/vue:ci",
        "build"
      ],
      "files": [],
      "output": [
        "dist/starters/vue/**"
      ]
    },
    "pages:elements": {
      "command": "cp -a ../elements/dist-storybook/. ./dist/api",
      "dependencies": [
        "../elements:build:storybook",
        "build"
      ],
      "files": [],
      "output": [
        "dist/api/**"
      ]
    },
    "build": {
      "command": "mkdir -p dist/starters && mkdir -p dist/api && cp -a ./_redirects dist/ && cp -a ./robots.txt dist/",
      "files": [
        "_redirects",
        "robots.txt"
      ],
      "output": [
        "dist/_redirects",
        "dist/robots.txt"
      ]
    },
    "preview": {
      "command": "cd dist && pnpm exec vite preview --base=elements",
      "dependencies": [
        "ci"
      ],
      "files": []
    }
  },
  "dependencies": {
    "vite": "5.2.9"
  }
}
