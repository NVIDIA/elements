{
  "name": "pages",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "command": "node ./index.js",
      "files": [
        "index.js",
        "_redirects",
        "robots.txt"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "../site:build",
        "../starters:build",
        "../internals/metadata:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/"
        }
      }
    },
    "preview": {
      "command": "pnpm run ci && vite preview --base=$PAGES_BASE_URL",
      "service": true,
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/"
        }
      }
    }
  },
  "dependencies": {
    "vite": "catalog:"
  }
}
