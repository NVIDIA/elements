{
  "name": "pages",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "node ./index.js",
      "files": [
        "index.js",
        "_redirects",
        "robots.txt"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "../storybook:build",
        "../starters:build",
        "../internals/metadata:build"
      ]
    },
    "preview": {
      "command": "cd dist && pnpm exec vite preview --base=elements",
      "dependencies": [
        "ci"
      ],
      "files": []
    }
  },
  "dependencies": {
    "vite": "catalog:"
  }
}
