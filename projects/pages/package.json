{
  "name": "pages",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "command": "node ./index.js",
      "files": [
        "index.js",
        "_redirects",
        "robots.txt"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "../storybook:build",
        "../starters/angular:ci",
        "../starters/buildless:ci",
        "../starters/mpa:ci",
        "../starters/react:ci",
        "../starters/solidjs:ci",
        "../starters/typescript:ci",
        "../starters/vue:ci"
      ]
    },
    "preview": {
      "command": "cd dist && pnpm exec vite preview --base=elements",
      "dependencies": [
        "ci"
      ],
      "files": []
    }
  },
  "dependencies": {
    "vite": "5.3.3"
  }
}
