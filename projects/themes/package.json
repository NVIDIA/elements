{
  "name": "@nvidia-elements/themes",
  "version": "0.29.2",
  "type": "module",
  "description": "Elements themes and tokens",
  "contributes": {
    "cssVars": {
      "customData": [
        "./dist/data.css-vars.json"
      ]
    }
  },
  "scripts": {
    "ci": "wireit",
    "build": "wireit",
    "test:lighthouse": "wireit"
  },
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "devDependencies": {
    "@nvidia-elements/testing-lighthouse": "workspace:*",
    "chart.js": "4.4.0",
    "cssnano": "6.0.1",
    "glob": "10.3.10",
    "lit": "3.1.3",
    "postcss": "8.4.31",
    "style-dictionary": "3.8.0",
    "vite": "5.3.3",
    "vitest": "2.0.3"
  },
  "exports": {
    "./package.json": "./package.json",
    "./CHANGELOG.md": "./CHANGELOG.md",
    "./data.css-vars.json": "./dist/data.css-vars.json",
    "./fonts/*": "./dist/fonts/*",
    "./*": "./dist/*"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "dependencies": [
        "build:css-var-completions",
        "build:styledictionary"
      ]
    },
    "build:styledictionary": {
      "command": "node ./build/style-dictionary.config.js && node ./build/style-dictionary.alias.js && node ./build/style-dictionary.minify.js && node ./build/fonts.js && node ./build/version.js",
      "files": [
        "src/**",
        "!src/**/*.test.lighthouse.ts",
        "build/style-dictionary.config.js",
        "build/style-dictionary.alias.js",
        "build/style-dictionary.minify.js"
      ],
      "output": [
        "dist/",
        "!dist/data.css-vars.json"
      ]
    },
    "build:css-var-completions": {
      "command": "node ./build/css-var-completions.js",
      "files": [
        "build/css-var-completions.js",
        "src/**",
        "!src/**/*.test.lighthouse.ts"
      ],
      "output": [
        "dist/data.css-vars.json"
      ],
      "dependencies": [
        "build:styledictionary"
      ]
    },
    "test:lighthouse": {
      "command": "vitest run --config=vitest.lighthouse.ts",
      "dependencies": [
        "build"
      ]
    }
  }
}
