{
  "name": "@nve-internal/metadata",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "ci:all": "wireit",
    "build": "wireit",
    "build:elements": "wireit",
    "build:lighthouse": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "ci:all": {
      "dependencies": [
        "build",
        "build:lighthouse",
        "build:elements"
      ]
    },
    "build": {
      "clean": false,
      "command": "node ./src/index.mjs",
      "files": [
        "src/index.mjs"
      ],
      "output": [
        "dist/index.json"
      ],
      "dependencies": [
        "../../elements:ci",
        "../../elements-react:ci",
        "../../testing:ci",
        "../../labs/code:ci"
      ]
    },
    "build:lighthouse": {
      "command": "node ./src/lighthouse.mjs",
      "files": [
        "src/lighthouse.mjs"
      ],
      "output": [
        "static/lighthouse.json"
      ],
      "dependencies": [
        "../../../:lighthouse"
      ]
    },
    "build:elements": {
      "command": "node ./src/elements.mjs",
      "files": [
        "src/elements.mjs"
      ],
      "output": [
        "static/elements.json"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    }
  },
  "dependencies": {
    "ts-morph": "20.0.0"
  }
}
