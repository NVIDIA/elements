{
  "name": "@nve-internals/metadata",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "node --experimental-strip-types ./src/metadata.ts",
    "ci": "wireit",
    "ci:all": "wireit",
    "build": "wireit",
    "build:tests": "wireit",
    "build:examples": "wireit",
    "build:metadata": "wireit",
    "build:usage": "wireit",
    "build:lighthouse": "wireit",
    "test": "wireit",
    "test:watch": "wireit",
    "test:coverage": "wireit",
    "lint": "wireit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./services/metadata.service.js": {
      "types": "./dist/services/metadata.service.d.ts",
      "default": "./dist/src/services/metadata.service.js"
    },
    "./services/tests.service.js": {
      "types": "./dist/services/tests.service.d.ts",
      "default": "./dist/src/services/tests.service.js"
    },
    "./services/usage.service.js": {
      "types": "./dist/services/usage.service.d.ts",
      "default": "./dist/src/services/usage.service.js"
    }
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "publint",
        "test:coverage"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "build": {
      "command": "NODE_ENV=production vite build",
      "files": [
        "src/**",
        "!src/**/*.test.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../vite:ci",
        "build:metadata",
        "build:examples",
        "build:tests"
      ]
    },
    "build:metadata": {
      "command": "node --experimental-strip-types ./src/tasks/metadata.ts",
      "files": [
        "./src/tasks/metadata.ts",
        "./src/tasks/metadata.utils.ts",
        "../../elements/src/internal/types/index.ts",
        "../../elements/package.json",
        "../../elements/README.md",
        "../../elements/CHANGELOG.md",
        "../../elements/dist/custom-elements.json",
        "../../elements-react/package.json",
        "../../elements-react/README.md",
        "../../elements-react/CHANGELOG.md",
        "../../elements-react/dist/custom-elements.json",
        "../../styles/package.json",
        "../../styles/README.md",
        "../../styles/CHANGELOG.md",
        "../../styles/dist/custom-elements.json",
        "../../testing/package.json",
        "../../testing/README.md",
        "../../testing/CHANGELOG.md",
        "../../testing/dist/custom-elements.json",
        "../../themes/package.json",
        "../../themes/README.md",
        "../../themes/CHANGELOG.md",
        "../../themes/dist/custom-elements.json",
        "../../labs/brand/package.json",
        "../../labs/brand/README.md",
        "../../labs/brand/CHANGELOG.md",
        "../../labs/brand/dist/custom-elements.json",
        "../../labs/code/package.json",
        "../../labs/code/README.md",
        "../../labs/code/CHANGELOG.md",
        "../../labs/code/dist/custom-elements.json",
        "../../labs/forms/package.json",
        "../../labs/forms/README.md",
        "../../labs/forms/CHANGELOG.md",
        "../../labs/forms/dist/custom-elements.json",
        "../../labs/behaviors-alpine/package.json",
        "../../labs/behaviors-alpine/README.md",
        "../../labs/behaviors-alpine/CHANGELOG.md",
        "../../labs/behaviors-alpine/dist/custom-elements.json",
        "../../labs/markdown/package.json",
        "../../labs/markdown/README.md",
        "../../labs/markdown/CHANGELOG.md",
        "../../labs/markdown/dist/custom-elements.json",
        "../../labs/playwright-screencast/package.json",
        "../../labs/playwright-screencast/README.md",
        "../../labs/playwright-screencast/CHANGELOG.md",
        "../../labs/playwright-screencast/dist/custom-elements.json",
        "../../monaco/package.json",
        "../../monaco/README.md",
        "../../monaco/CHANGELOG.md",
        "../../monaco/dist/custom-elements.json",
        "../../patterns/package.json",
        "../../patterns/dist/custom-elements.json"
      ],
      "output": [
        "static/index.json"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../elements-react:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../testing:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        },
        {
          "script": "../../labs/brand:build",
          "cascade": false
        },
        {
          "script": "../../labs/code:build",
          "cascade": false
        },
        {
          "script": "../../labs/forms:build",
          "cascade": false
        },
        {
          "script": "../../labs/markdown:build",
          "cascade": false
        },
        {
          "script": "../../monaco:build",
          "cascade": false
        },
        {
          "script": "../../labs/behaviors-alpine:build",
          "cascade": false
        },
        {
          "script": "../../labs/playwright-screencast:build",
          "cascade": false
        },
        {
          "script": "../patterns:build",
          "cascade": false
        }
      ]
    },
    "build:tests": {
      "command": "node --experimental-strip-types ./src/tasks/tests.ts",
      "files": [
        "./src/tasks/tests.ts",
        "./src/tasks/tests.utils.ts",
        "./static/lighthouse.json",
        "../../elements/coverage/unit/coverage-summary.json",
        "../../elements/coverage/unit/summary.json",
        "../../elements/coverage/visual/summary.json",
        "../../elements/coverage/ssr/summary.json",
        "../../elements-react/coverage/unit/coverage-summary.json",
        "../../elements-react/coverage/unit/summary.json",
        "../../styles/coverage/visual/summary.json",
        "../../themes/coverage/visual/summary.json",
        "../../labs/brand/coverage/unit/coverage-summary.json",
        "../../labs/brand/coverage/unit/summary.json",
        "../../labs/brand/coverage/visual/summary.json",
        "../../labs/code/coverage/unit/coverage-summary.json",
        "../../labs/code/coverage/unit/summary.json",
        "../../labs/code/coverage/visual/summary.json",
        "../../labs/code/coverage/ssr/summary.json",
        "../../labs/forms/coverage/unit/coverage-summary.json",
        "../../labs/forms/coverage/unit/summary.json",
        "../../labs/behaviors-alpine/coverage/unit/coverage-summary.json",
        "../../labs/behaviors-alpine/coverage/unit/summary.json",
        "../../labs/markdown/coverage/unit/coverage-summary.json",
        "../../labs/markdown/coverage/unit/summary.json",
        "../../labs/markdown/coverage/visual/summary.json",
        "../../labs/markdown/coverage/ssr/summary.json",
        "../../labs/playwright-screencast/coverage/unit/coverage-summary.json",
        "../../labs/playwright-screencast/coverage/unit/summary.json",
        "../../monaco/coverage/unit/coverage-summary.json",
        "../../monaco/coverage/unit/summary.json",
        "../../monaco/coverage/visual/summary.json",
        "../../monaco/coverage/ssr/summary.json"
      ],
      "output": [
        "static/tests.json"
      ],
      "dependencies": [
        {
          "script": "../../elements:test:coverage",
          "cascade": false
        },
        {
          "script": "../../elements:test:ssr",
          "cascade": false
        },
        {
          "script": "../../elements:test:visual",
          "cascade": false
        },
        {
          "script": "../../elements-react:test:coverage",
          "cascade": false
        },
        {
          "script": "../../styles:test:visual",
          "cascade": false
        },
        {
          "script": "../../themes:test:visual",
          "cascade": false
        },
        {
          "script": "../../labs/brand:test",
          "cascade": false
        },
        {
          "script": "../../labs/brand:test:visual",
          "cascade": false
        },
        {
          "script": "../../labs/code:test:coverage",
          "cascade": false
        },
        {
          "script": "../../labs/forms:test:coverage",
          "cascade": false
        },
        {
          "script": "../../labs/markdown:test:coverage",
          "cascade": false
        },
        {
          "script": "../../monaco:test:coverage",
          "cascade": false
        },
        {
          "script": "../../labs/behaviors-alpine:test:coverage",
          "cascade": false
        },
        {
          "script": "../../labs/playwright-screencast:test:coverage",
          "cascade": false
        }
      ]
    },
    "build:examples": {
      "command": "node --experimental-strip-types ./src/tasks/examples.ts",
      "files": [
        "./src/tasks/examples.ts",
        "./src/tasks/examples.utils.ts",
        "./src/utils/utils.ts",
        "../../elements/dist/**/*.stories.json",
        "../../elements-react/dist/**/*.stories.json",
        "../../styles/dist/**/*.stories.json",
        "../../testing/dist/**/*.stories.json",
        "../../themes/dist/**/*.stories.json",
        "../../labs/brand/dist/**/*.stories.json",
        "../../labs/code/dist/**/*.stories.json",
        "../../labs/forms/dist/**/*.stories.json",
        "../../labs/markdown/dist/**/*.stories.json",
        "../../labs/behaviors-alpine/dist/**/*.stories.json",
        "../../labs/playwright-screencast/dist/**/*.stories.json",
        "../../monaco/dist/**/*.stories.json",
        "../../patterns/dist/**/*.stories.json"
      ],
      "output": [
        "static/examples.json"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../elements-react:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../testing:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        },
        {
          "script": "../../labs/brand:build",
          "cascade": false
        },
        {
          "script": "../../labs/code:build",
          "cascade": false
        },
        {
          "script": "../../labs/forms:build",
          "cascade": false
        },
        {
          "script": "../../monaco:build",
          "cascade": false
        },
        {
          "script": "../../labs/behaviors-alpine:build",
          "cascade": false
        },
        {
          "script": "../../labs/playwright-screencast:build",
          "cascade": false
        },
        {
          "script": "../patterns:build",
          "cascade": false
        }
      ]
    },
    "build:lighthouse": {
      "command": "node --experimental-strip-types ./src/tasks/lighthouse.ts",
      "files": [
        "src/tasks/lighthouse.ts",
        "src/tasks/lighthouse.utils.ts"
      ],
      "output": [
        "static/lighthouse.json"
      ],
      "dependencies": [
        "../../../:lighthouse"
      ]
    },
    "build:usage": {
      "command": "node --experimental-strip-types ./src/tasks/usage.ts",
      "files": [
        "src/tasks/usage.ts",
        "src/tasks/usage.utils.ts"
      ],
      "output": [
        "static/usage.json"
      ],
      "dependencies": [
        "../../elements:build",
        "build:metadata"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../eslint:ci",
        "../../labs/lint:build"
      ]
    },
    "test": {
      "command": "vitest run",
      "files": [
        "dist/**/*.js",
        "static/**/*.json",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "../vite:ci",
        "build"
      ]
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "dist/**/*.js",
        "static/**/*.json",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/unit/**"
      ],
      "dependencies": [
        "../vite:ci",
        "build"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "dependencies": {
    "glob": "catalog:",
    "ts-morph": "catalog:"
  },
  "devDependencies": {
    "@nve-internals/eslint": "workspace:*",
    "@nve-internals/vite": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
