{
  "name": "@internals/metadata",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "node --experimental-strip-types ./src/metadata.ts",
    "ci": "wireit",
    "ci:all": "wireit",
    "build": "wireit",
    "build:metadata": "wireit",
    "build:av-infra": "wireit",
    "build:lighthouse": "wireit",
    "test": "wireit",
    "test:watch": "wireit",
    "test:coverage": "wireit",
    "lint": "wireit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./services/metadata.service.js": {
      "types": "./dist/services/metadata.service.d.ts",
      "default": "./dist/src/services/metadata.service.js"
    },
    "./services/av-infra.service.js": {
      "types": "./dist/services/av-infra.service.d.ts",
      "default": "./dist/src/services/av-infra.service.js"
    }
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "publint",
        "test:coverage"
      ]
    },
    "ci:all": {
      "dependencies": [
        "build",
        "build:lighthouse",
        "build:av-infra"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "build": {
      "command": "NODE_ENV=production vite build",
      "files": [
        "src/**",
        "!src/**/*.test.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../vite:ci",
        "build:metadata",
        "build:stories"
      ]
    },
    "build:metadata": {
      "command": "node --experimental-strip-types ./src/tasks/metadata.ts",
      "files": [
        "./src/tasks/metadata.ts",
        "./src/tasks/metadata.utils.ts",
        "./static/lighthouse.json",
        "../../elements/src/internal/types/index.ts",
        "../../elements/package.json",
        "../../elements/README.md",
        "../../elements/CHANGELOG.md",
        "../../elements/dist/custom-elements.json",
        "../../elements/coverage/unit/coverage-summary.json",
        "../../elements/coverage/unit/junit.xml",
        "../../elements/coverage/axe/junit.xml",
        "../../elements/coverage/visual/junit.xml",
        "../../elements/coverage/ssr/junit.xml",
        "../../elements/coverage/ssr/summary.json",
        "../../elements-react/package.json",
        "../../elements-react/README.md",
        "../../elements-react/CHANGELOG.md",
        "../../elements-react/dist/custom-elements.json",
        "../../elements-react/coverage/unit/coverage-summary.json",
        "../../elements-react/coverage/unit/junit.xml",
        "../../elements-react/coverage/axe/junit.xml",
        "../../elements-react/coverage/visual/junit.xml",
        "../../elements-react/coverage/ssr/junit.xml",
        "../../elements-react/coverage/ssr/summary.json",
        "../../styles/package.json",
        "../../styles/README.md",
        "../../styles/CHANGELOG.md",
        "../../styles/dist/custom-elements.json",
        "../../styles/coverage/unit/coverage-summary.json",
        "../../styles/coverage/unit/junit.xml",
        "../../styles/coverage/axe/junit.xml",
        "../../styles/coverage/visual/junit.xml",
        "../../styles/coverage/ssr/junit.xml",
        "../../styles/coverage/ssr/summary.json",
        "../../testing/package.json",
        "../../testing/README.md",
        "../../testing/CHANGELOG.md",
        "../../testing/dist/custom-elements.json",
        "../../testing/coverage/unit/coverage-summary.json",
        "../../testing/coverage/unit/junit.xml",
        "../../testing/coverage/axe/junit.xml",
        "../../testing/coverage/visual/junit.xml",
        "../../testing/coverage/ssr/junit.xml",
        "../../testing/coverage/ssr/summary.json",
        "../../themes/package.json",
        "../../themes/README.md",
        "../../themes/CHANGELOG.md",
        "../../themes/dist/custom-elements.json",
        "../../themes/coverage/unit/coverage-summary.json",
        "../../themes/coverage/unit/junit.xml",
        "../../themes/coverage/axe/junit.xml",
        "../../themes/coverage/visual/junit.xml",
        "../../themes/coverage/ssr/junit.xml",
        "../../themes/coverage/ssr/summary.json",
        "../../labs/brand/package.json",
        "../../labs/brand/README.md",
        "../../labs/brand/CHANGELOG.md",
        "../../labs/brand/dist/custom-elements.json",
        "../../labs/brand/coverage/unit/coverage-summary.json",
        "../../labs/brand/coverage/unit/junit.xml",
        "../../labs/brand/coverage/axe/junit.xml",
        "../../labs/brand/coverage/visual/junit.xml",
        "../../labs/brand/coverage/ssr/junit.xml",
        "../../labs/brand/coverage/ssr/summary.json",
        "../../labs/code/package.json",
        "../../labs/code/README.md",
        "../../labs/code/CHANGELOG.md",
        "../../labs/code/dist/custom-elements.json",
        "../../labs/code/coverage/unit/coverage-summary.json",
        "../../labs/code/coverage/unit/junit.xml",
        "../../labs/code/coverage/axe/junit.xml",
        "../../labs/code/coverage/visual/junit.xml",
        "../../labs/code/coverage/ssr/junit.xml",
        "../../labs/code/coverage/ssr/summary.json",
        "../../labs/forms/package.json",
        "../../labs/forms/README.md",
        "../../labs/forms/CHANGELOG.md",
        "../../labs/forms/dist/custom-elements.json",
        "../../labs/forms/coverage/unit/coverage-summary.json",
        "../../labs/forms/coverage/unit/junit.xml",
        "../../labs/forms/coverage/axe/junit.xml",
        "../../labs/forms/coverage/visual/junit.xml",
        "../../labs/forms/coverage/ssr/junit.xml",
        "../../labs/forms/coverage/ssr/summary.json",
        "../../labs/behaviors-alpine/package.json",
        "../../labs/behaviors-alpine/README.md",
        "../../labs/behaviors-alpine/CHANGELOG.md",
        "../../labs/behaviors-alpine/dist/custom-elements.json",
        "../../labs/behaviors-alpine/coverage/unit/coverage-summary.json",
        "../../labs/behaviors-alpine/coverage/unit/junit.xml",
        "../../labs/behaviors-alpine/coverage/axe/junit.xml",
        "../../labs/behaviors-alpine/coverage/visual/junit.xml",
        "../../labs/behaviors-alpine/coverage/ssr/junit.xml",
        "../../labs/behaviors-alpine/coverage/ssr/summary.json",
        "../../labs/playwright-screencast/package.json",
        "../../labs/playwright-screencast/README.md",
        "../../labs/playwright-screencast/CHANGELOG.md",
        "../../labs/playwright-screencast/dist/custom-elements.json",
        "../../labs/playwright-screencast/coverage/unit/coverage-summary.json",
        "../../labs/playwright-screencast/coverage/unit/junit.xml",
        "../../labs/playwright-screencast/coverage/axe/junit.xml",
        "../../labs/playwright-screencast/coverage/visual/junit.xml",
        "../../labs/playwright-screencast/coverage/ssr/junit.xml",
        "../../labs/playwright-screencast/coverage/ssr/summary.json",
        "../../monaco/package.json",
        "../../monaco/README.md",
        "../../monaco/CHANGELOG.md",
        "../../monaco/dist/custom-elements.json",
        "../../monaco/coverage/unit/coverage-summary.json",
        "../../monaco/coverage/unit/junit.xml",
        "../../monaco/coverage/axe/junit.xml",
        "../../monaco/coverage/visual/junit.xml",
        "../../monaco/coverage/ssr/junit.xml",
        "../../monaco/coverage/ssr/summary.json",
        "../../patterns/package.json",
        "../../patterns/dist/custom-elements.json"
      ],
      "output": [
        "static/index.json"
      ],
      "dependencies": [
        {
          "script": "../../elements:ci",
          "cascade": false
        },
        {
          "script": "../../elements-react:ci",
          "cascade": false
        },
        {
          "script": "../../styles:ci",
          "cascade": false
        },
        {
          "script": "../../testing:ci",
          "cascade": false
        },
        {
          "script": "../../themes:ci",
          "cascade": false
        },
        {
          "script": "../../labs/brand:ci",
          "cascade": false
        },
        {
          "script": "../../labs/code:ci",
          "cascade": false
        },
        {
          "script": "../../labs/forms:ci",
          "cascade": false
        },
        {
          "script": "../../monaco:ci",
          "cascade": false
        },
        {
          "script": "../../labs/behaviors-alpine:ci",
          "cascade": false
        },
        {
          "script": "../../labs/playwright-screencast:ci",
          "cascade": false
        },
        {
          "script": "../patterns:ci",
          "cascade": false
        }
      ]
    },
    "build:stories": {
      "command": "node --experimental-strip-types ./src/tasks/stories.ts",
      "files": [
        "./src/tasks/stories.ts",
        "./src/tasks/stories.utils.ts",
        "../../elements/dist/**/*.stories.json",
        "../../elements-react/dist/**/*.stories.json",
        "../../styles/dist/**/*.stories.json",
        "../../testing/dist/**/*.stories.json",
        "../../themes/dist/**/*.stories.json",
        "../../labs/brand/dist/**/*.stories.json",
        "../../labs/code/dist/**/*.stories.json",
        "../../labs/forms/dist/**/*.stories.json",
        "../../labs/behaviors-alpine/dist/**/*.stories.json",
        "../../labs/playwright-screencast/dist/**/*.stories.json",
        "../../monaco/dist/**/*.stories.json",
        "../../patterns/dist/**/*.stories.json"
      ],
      "output": [
        "static/stories.json"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../elements-react:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../testing:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        },
        {
          "script": "../../labs/brand:build",
          "cascade": false
        },
        {
          "script": "../../labs/code:build",
          "cascade": false
        },
        {
          "script": "../../labs/forms:build",
          "cascade": false
        },
        {
          "script": "../../monaco:build",
          "cascade": false
        },
        {
          "script": "../../labs/behaviors-alpine:build",
          "cascade": false
        },
        {
          "script": "../../labs/playwright-screencast:build",
          "cascade": false
        },
        {
          "script": "../patterns:build",
          "cascade": false
        }
      ]
    },
    "build:lighthouse": {
      "command": "node --experimental-strip-types ./src/tasks/lighthouse.ts",
      "files": [
        "src/tasks/lighthouse.ts",
        "src/tasks/lighthouse.utils.ts"
      ],
      "output": [
        "static/lighthouse.json"
      ],
      "dependencies": [
        "../../../:lighthouse"
      ]
    },
    "build:av-infra": {
      "command": "node --experimental-strip-types ./src/tasks/metadata.av-infra.ts",
      "files": [
        "src/tasks/metadata.av-infra.ts",
        "src/tasks/metadata.av-infra.utils.ts"
      ],
      "output": [
        "static/av-infra.json"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix"
    },
    "test": {
      "command": "vitest run",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "../vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ]
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/unit/**"
      ],
      "dependencies": [
        "../vite:ci",
        "build"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "dependencies": {
    "glob": "catalog:",
    "ts-morph": "catalog:"
  },
  "devDependencies": {
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
