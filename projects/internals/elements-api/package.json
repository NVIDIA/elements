{
  "name": "@internals/elements-api",
  "version": "0.0.0",
  "description": "Elements API and Documentation components",
  "homepage": "https://NVIDIA.github.io/elements/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NVIDIA/elements.git"
  },
  "type": "module",
  "customElements": "custom-elements.json",
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./custom-elements.json": "./dist/custom-elements.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "default": "./dist/canvas/index.js"
    },
    "./canvas/index.js": {
      "types": "./dist/canvas/index.d.ts",
      "default": "./dist/canvas/index.js"
    },
    "./canvas/define.js": {
      "types": "./dist/canvas/define.d.ts",
      "default": "./dist/canvas/define.js"
    },
    "./system-settings": {
      "types": "./dist/system-settings/index.d.ts",
      "default": "./dist/system-settings/index.js"
    },
    "./system-settings/index.js": {
      "types": "./dist/system-settings/index.d.ts",
      "default": "./dist/system-settings/index.js"
    },
    "./system-settings/define.js": {
      "types": "./dist/system-settings/define.d.ts",
      "default": "./dist/system-settings/define.js"
    }
  },
  "sideEffects": [
    "./**/define.js"
  ],
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "build:watch": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "@internals/metadata": "workspace:*",
    "fflate": "0.8.2",
    "html-format": "1.1.7",
    "lit": "catalog:",
    "showdown": "2.1.0"
  },
  "peerDependencies": {
    "@nvidia-elements/core": "workspace:^",
    "@nvidia-elements/code": "workspace:^"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/testing": "workspace:*",
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "wireit": {
    "dev": {
      "command": "vite",
      "dependencies": [
        "build",
        "build:watch",
        "../../storybook:dev"
      ]
    },
    "ci": {
      "dependencies": [
        "build",
        "lint",
        "publint"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "build": {
      "command": "NODE_ENV=production vite build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../labs/code/dist/**/*.js",
        "src/**",
        "!src/**/*.stories.ts",
        "!src/**/*.mdx",
        "!src/**/*.test.ts",
        "!src/**/*.test.lighthouse.ts",
        "!src/**/*.test.visual.ts",
        "!src/**/*.test.axe.ts",
        "!src/**/*.test.ssr.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../../internals/vite:ci",
        "../../internals/metadata:build",
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../labs/code:build",
          "cascade": false
        }
      ]
    },
    "build:watch": {
      "command": "vite build --watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../internals/eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix"
    }
  }
}
