    "./internal": "./dist/internal/index.js",
    "./internal/index.js": "./dist/internal/index.js"
  },
  "typesVersions": {
    "*": {
      "index": [
        "dist/index.d.ts"
      ],
      "*/define": [
        "dist/*/define.d.ts"
      ],
      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@floating-ui/dom": "1.6.1",
    "@lit-labs/motion": "^1.0.7",
    "@nvidia-elements/themes": "workspace:^",
    "composed-offset-position": "^0.0.4",
    "lit": "^3.1.3",
    "lit-html": "^3.1.3"
  },
  "optionalDependencies": {
    "@lit-labs/scoped-registry-mixin": "^1.0.3",
    "@webcomponents/scoped-custom-element-registry": "^0.0.9",
    "construct-style-sheets-polyfill": "^3.1.0",
    "element-internals-polyfill": "^1.3.11",
    "formdata-polyfill": "^4.0.10"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.10.2",
    "@eslint/js": "9.4.0",
    "@jspm/generator": "1.1.12",
    "@lit-labs/virtualizer": "2.0.12",
    "@nvidia-elements/testing": "workspace:*",
    "@nvidia-elements/testing-lighthouse": "workspace:*",
    "@internals/vite": "workspace:*",
    "@rollup/plugin-terser": "0.4.4",
    "@typescript/lib-dom": "npm:@types/web@0.0.147",
    "@vitest/browser": "1.6.0",
    "@vitest/coverage-istanbul": "1.6.0",
    "chai": "4.3.10",
    "cssnano": "6.0.1",
    "emoji-picker-element": "1.18.4",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-lit": "1.14.0",
    "eslint-plugin-lit-a11y": "4.1.2",
    "eslint-plugin-rulesdir": "0.2.2",
    "eslint-plugin-wc": "2.1.0",
    "glob": "10.3.10",
    "globals": "13.23.0",
    "lighthouse": "11.4.0",
    "lit-analyzer": "2.0.3",
    "postcss": "8.4.31",
    "postcss-each": "1.1.0",
    "postcss-load-config": "4.0.1",
    "postcss-mixins": "9.0.4",
    "regenerator-runtime": "0.13.10",
    "style-dictionary": "3.8.0",
    "svgo": "3.0.2",
    "terser": "5.30.3",
    "ts-lit-plugin": "2.0.2",
    "ts-morph": "20.0.0",
    "typescript-eslint": "7.12.0",
    "typescript": "5.3.3",
    "vite": "5.2.11",
    "vitest": "1.6.0"
  },
  "wireit": {
    "dev": {
      "dependencies": [
        "build:watch",
        "../storybook:dev"
      ]
    },
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "test:all"
      ]
    },
    "build": {
      "clean": false,
      "dependencies": [
        "build:tsc",
        "build:vite",
        "build:bundle",
        "build:manifest",
        "build:vscode-custom-data"
      ]
    },
    "build:watch": {
      "command": "vite build --watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "build:tsc": {
      "command": "tsc --project ./tsconfig.lib.json --noEmit --emitDeclarationOnly false",
      "files": [
        "src/**/*.ts",
        "src/**/*.stories.ts",
        "!src/**/*.test.ts",
        "!src/**/*.test.axe.ts",
        "!src/**/*.test.lighthouse.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json"
      ],
      "output": []
    },
    "build:vite": {
      "clean": false,
      "command": "NODE_ENV=production vite build",
      "files": [
        "public/**",
        "src/**",
        "!src/test/lighthouse/**",
        "!src/**/*.stories.ts",
        "!src/**/*.stories.mdx",
        "!src/**/*.test.ts",
        "!src/**/*.test.axe.ts",
        "!src/**/*.test.lighthouse.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "postcss.config.cjs"
      ],
      "output": [
        "dist/**",
        "!dist/custom-elements.json",
        "!dist/elements.css-vars.json",
        "!dist/elements.html-data.json",
        "!dist/importmap.cdn.json"
      ],
      "dependencies": [
        "build:icons",
        "build:manifest",
        "build:inter",
        "../themes:build",
        "../internals/vite:build"
      ]
    },
    "build:bundle": {
      "clean": false,
      "command": "NODE_ENV=production vite build --config vite.bundle.ts",
      "files": [
        "vite.bundle.ts",
        "package.json"
      ],
      "output": [
        "dist/bundles"
      ],
      "dependencies": [
        "build:vite"
      ]
    },
    "build:importmap": {
      "command": "node ./build/importmap.mjs --outDir ./dist",
      "files": [
        "build/importmap.mjs"
      ],
      "output": [
        "dist/importmap.cdn.json"
      ],
      "dependencies": [
        "build:vite"
      ]
    },
    "build:icons": {
      "command": "node ./build/icons.js",
      "clean": false,
      "files": [
        "src/icon/**",
        "!src/icon/icons.ts",
        "build/icons.js"
      ],
      "output": [
        "src/icon/icons.ts"
      ]
    },
    "build:inter": {
      "command": "node ./build/inter.js",
      "clean": false,
      "dependencies": [
        "../themes:build"
      ],
      "files": [
        "build/inter.js"
      ],
      "output": [
        "dist/inter.css",
        "dist/inter.woff"
      ]
    },
    "build:manifest": {
      "command": "cem analyze --config ./custom-elements-manifest.config.mjs --outdir ./dist/",
      "files": [
        "src/**",
        "!src/test/**",
        "!src/**/*.stories.ts",
        "!src/**/*.stories.mdx",
        "!src/**/*.test.ts",
        "!src/**/*.test.lighthouse.ts",
        "custom-elements-manifest.config.mjs"
      ],
      "output": [
        "dist/custom-elements.json"
      ]
    },
    "build:vscode-custom-data": {
      "command": "node ./build/vscode-custom-data.js --outDir ./dist",
      "files": [
        "build/vscode-custom-data.js"
      ],
      "output": [
        "dist/elements.html-data.json"
      ],
      "dependencies": [
        "build:manifest"
      ]
    },
    "test:all": {
      "command": "WIREIT_PARALLEL=1 echo '...'",
      "files": [],
      "output": [],
      "dependencies": [
        "test",
        "test:axe",
        "test:coverage",
        "test:lighthouse"
      ]
    },
    "test": {
      "command": "vitest run || exit 0",
      "files": [
        "src/**/*.test.ts",
        "!src/**/*.test.lighthouse.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "build",
        "../testing:ci"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "src/**/*.test.ts",
        "!src/**/*.test.lighthouse.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/unit/**"
      ],
      "dependencies": [
        "test",
        "build"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "test:lighthouse": {
      "command": "vitest run --config=vitest.lighthouse.ts",
      "files": [
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.html",
        "vitest.lighthouse.ts",
        "vitest.lighthouse.build.ts"
      ],
      "output": [
        ".lighthouse",
        "coverage/lighthouse/**"
      ],
      "dependencies": [
        "build",
        "../labs/testing-lighthouse:ci"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:lighthouse:all": {
      "command": "vitest run --config=vitest.lighthouse.ts",
      "files": [
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.html",
        "vitest.lighthouse.ts"
      ],
      "output": [
        ".lighthouse"
      ],
      "dependencies": [
        "build",
        "../labs/testing-lighthouse:ci"
      ],
      "env": {
        "LIGHTHOUSE_ALL": "true"
      }
    },
    "test:axe": {
      "command": "vitest run --config=vitest.axe.ts",
      "files": [
        "src/**/*.test.axe.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.axe.ts"
      ],
      "output": [
        "coverage/axe/**"
      ],
      "dependencies": [
        "build"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "lint:analyzer"
      ]
    },
    "lint:eslint": {
      "command": "eslint -c ./eslint.config.js ./src/**/*.ts",
      "files": [
        "../internals/eslint/*.cjs",
        "src/**/*.ts",
        "src/**/*.js",
        "eslint.config.js",
        "!./lighthouse/dist/**"
      ],
      "output": []
    },
    "lint:analyzer": {
      "command": "lit-analyzer src/**/*.ts --strict --rules.no-unknown-slot off",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": []
    },
    "prepublishonly": {
      "dependencies": [
        "ci",
        "../internals/metadata:ci"
      ]
    }
  }
}
