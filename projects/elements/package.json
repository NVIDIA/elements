{
  "name": "@elements/elements",
  "version": "0.8.0",
  "type": "module",
  "customElements": "custom-elements.json",
  "scripts": {
    "ci": "wireit",
    "ci:nocache": "wireit",
    "dev": "wireit",
    "clean": "wireit",
    "build": "wireit",
    "build:watch": "wireit",
    "test": "wireit",
    "test:watch": "wireit",
    "test:unit": "wireit",
    "test:coverage": "wireit",
    "storybook": "wireit",
    "storybook:watch": "wireit",
    "lint": "wireit",
    "lint:eslint": "wireit",
    "lint:repo": "wireit",
    "lint:analyzer": "wireit",
    "demos": "wireit",
    "create-icon-spritesheet": "wireit",
    "prepublishonly": "wireit"
  },
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/polyfills/index.js",
    "./dist/test/index.js",
    "./**/define.js"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./custom-elements.json": "./dist/custom-elements.json",
    "./tokens/tokens.json": "./dist/tokens/tokens.json",
    "./assets/*": "./dist/assets/*",
    "./css/*": "./dist/css/*",
    ".": "./dist/index.js",
    "./index.js": "./dist/index.js",
    "./index.css": "./dist/index.css",
    "./inter.css": "./dist/inter.css",
    "./internal": "./dist/internal/index.js",
    "./internal/index.js": "./dist/internal/index.js",
    "./test": "./dist/test/index.js",
    "./test/index.js": "./dist/test/index.js",
    "./polyfills": "./dist/polyfills/index.js",
    "./polyfills/index.js": "./dist/polyfills/index.js",
    "./alert": "./dist/alert/index.js",
    "./alert/index.js": "./dist/alert/index.js",
    "./alert/define.js": "./dist/alert/define.js",
    "./button": "./dist/button/index.js",
    "./button/index.js": "./dist/button/index.js",
    "./button/define.js": "./dist/button/define.js",
    "./card": "./dist/card/index.js",
    "./card/index.js": "./dist/card/index.js",
    "./card/define.js": "./dist/card/define.js",
    "./checkbox": "./dist/checkbox/index.js",
    "./checkbox/index.js": "./dist/checkbox/index.js",
    "./checkbox/define.js": "./dist/checkbox/define.js",
    "./color": "./dist/color/index.js",
    "./color/index.js": "./dist/color/index.js",
    "./color/define.js": "./dist/color/define.js",
    "./date": "./dist/date/index.js",
    "./date/index.js": "./dist/date/index.js",
    "./date/define.js": "./dist/date/define.js",
    "./datetime": "./dist/datetime/index.js",
    "./datetime/index.js": "./dist/datetime/index.js",
    "./datetime/define.js": "./dist/datetime/define.js",
    "./dialog": "./dist/dialog/index.js",
    "./dialog/index.js": "./dist/dialog/index.js",
    "./dialog/define.js": "./dist/dialog/define.js",
    "./dropdown": "./dist/dropdown/index.js",
    "./dropdown/index.js": "./dist/dropdown/index.js",
    "./dropdown/define.js": "./dist/dropdown/define.js",
    "./file": "./dist/file/index.js",
    "./file/index.js": "./dist/file/index.js",
    "./file/define.js": "./dist/file/define.js",
    "./forms": "./dist/forms/index.js",
    "./forms/index.js": "./dist/forms/index.js",
    "./forms/define.js": "./dist/forms/define.js",
    "./icon": "./dist/icon/index.js",
    "./icon/index.js": "./dist/icon/index.js",
    "./icon/define.js": "./dist/icon/define.js",
    "./icon-button": "./dist/icon-button/index.js",
    "./icon-button/index.js": "./dist/icon-button/index.js",
    "./icon-button/define.js": "./dist/icon-button/define.js",
    "./input": "./dist/input/index.js",
    "./input/index.js": "./dist/input/index.js",
    "./input/define.js": "./dist/input/define.js",
    "./month": "./dist/month/index.js",
    "./month/index.js": "./dist/month/index.js",
    "./month/define.js": "./dist/month/define.js",
    "./notification": "./dist/notification/index.js",
    "./notification/index.js": "./dist/notification/index.js",
    "./notification/define.js": "./dist/notification/define.js",
    "./password": "./dist/password/index.js",
    "./password/index.js": "./dist/password/index.js",
    "./password/define.js": "./dist/password/define.js",
    "./radio": "./dist/radio/index.js",
    "./radio/index.js": "./dist/radio/index.js",
    "./radio/define.js": "./dist/radio/define.js",
    "./range": "./dist/range/index.js",
    "./range/index.js": "./dist/range/index.js",
    "./range/define.js": "./dist/range/define.js",
    "./scoped": "./dist/scoped/index.js",
    "./scoped/index.js": "./dist/scoped/index.js",
    "./scoped/define.js": "./dist/scoped/define.js",
    "./search": "./dist/search/index.js",
    "./search/index.js": "./dist/search/index.js",
    "./search/define.js": "./dist/search/define.js",
    "./select": "./dist/select/index.js",
    "./select/index.js": "./dist/select/index.js",
    "./select/define.js": "./dist/select/define.js",
    "./switch": "./dist/switch/index.js",
    "./switch/index.js": "./dist/switch/index.js",
    "./switch/define.js": "./dist/switch/define.js",
    "./toast": "./dist/toast/index.js",
    "./toast/index.js": "./dist/toast/index.js",
    "./toast/define.js": "./dist/toast/define.js",
    "./time": "./dist/time/index.js",
    "./time/index.js": "./dist/time/index.js",
    "./time/define.js": "./dist/time/define.js",
    "./textarea": "./dist/textarea/index.js",
    "./textarea/index.js": "./dist/textarea/index.js",
    "./textarea/define.js": "./dist/textarea/define.js",
    "./tooltip": "./dist/tooltip/index.js",
    "./tooltip/index.js": "./dist/tooltip/index.js",
    "./tooltip/define.js": "./dist/tooltip/define.js",
    "./week": "./dist/week/index.js",
    "./week/index.js": "./dist/week/index.js",
    "./week/define.js": "./dist/week/define.js"
  },
  "typesVersions": {
    "*": {
      "*/define": [
        "dist/*/define.d.ts"
      ],
      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "pnpm": {
    "overrides": {
      "rollup-plugin-minify-html-literals": {
        "rollup@^0.65.2 || ^1.0.0 || ^2.0.0": "$rollup"
      }
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.0.3",
    "@lit-labs/motion": "^1.0.3",
    "lit": "^2.4.0",
    "lit-html": "^2.4.0"
  },
  "optionalDependencies": {
    "@lit-labs/scoped-registry-mixin": "^1.0.1",
    "@webcomponents/scoped-custom-element-registry": "^0.0.8",
    "construct-style-sheets-polyfill": "^3.1.0",
    "element-internals-polyfill": "^1.1.18"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.6.3",
    "@geometricpanda/storybook-addon-badges": "0.2.2",
    "@lit-labs/react": "1.0.9",
    "@elements/custom-elements-storybook": "0.1.7",
    "@rollup/plugin-replace": "5.0.2",
    "@rollup/plugin-terser": "0.1.0",
    "@typescript-eslint/eslint-plugin": "5.47.0",
    "@typescript-eslint/parser": "5.47.0",
    "@typescript/lib-dom": "npm:@types/web@0.0.87",
    "@vitest/coverage-c8": "0.26.0",
    "emoji-picker-element": "1.12.1",
    "eslint": "8.30.0",
    "eslint-plugin-lit": "1.7.2",
    "eslint-plugin-lit-a11y": "2.3.0",
    "eslint-plugin-wc": "1.4.0",
    "glob": "8.0.3",
    "happy-dom": "8.1.0",
    "lit-analyzer": "1.2.1",
    "postcss": "8.4.16",
    "postcss-csso": "6.0.1",
    "postcss-each": "1.1.0",
    "postcss-mixins": "9.0.4",
    "postcss-nested": "5.0.6",
    "prettier": "2.5.1",
    "rollup": "3.7.5",
    "rollup-plugin-minify-html-literals": "1.2.6",
    "style-dictionary": "3.7.1",
    "svgo": "2.8.0",
    "ts-lit-plugin": "1.2.1",
    "typescript": "4.8.4",
    "vite": "4.0.2",
    "vite-plugin-dts": "1.7.1",
    "vitest": "0.25.8"
  },
  "publishConfig": {
    "registry": "https://artifactory.build.nvidia.com/artifactory/api/npm/elements-ui-npm/"
  },
  "wireit": {
    "dev": {
      "dependencies": [
        "build:watch",
        "storybook:watch"
      ]
    },
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "test",
        "test:coverage",
        "storybook",
        "demos"
      ]
    },
    "ci:nocache": {
      "command": "pnpm i && pnpm run ci",
      "dependencies": [
        "clean"
      ]
    },
    "build": {
      "command": "vite build",
      "files": [
        "public/**",
        "src/**",
        "!src/**/*.stories.ts",
        "!src/**/*.stories.mdx",
        "!src/**/*.test.ts",
        "tokens/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "create-icon-spritesheet"
      ]
    },
    "build:watch": {
      "command": "vite build --mode watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "clean": {
      "command": "git clean -dfX"
    },
    "test": {
      "command": "vitest run",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "build"
      ]
    },
    "test:watch": {
      "command": "pnpm run test:unit --watch",
      "output": []
    },
    "test:unit": {
      "command": "vitest run",
      "files": [
        "dist/**",
        "src/**/*.test.ts"
      ],
      "output": []
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/**"
      ],
      "dependencies": [
        "build"
      ]
    },
    "demos": {
      "dependencies": [
        "../demos/static:build",
        "../demos/typescript:build",
        "../demos/extensions:build"
      ]
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "lint:repo"
      ]
    },
    "lint:eslint": {
      "command": "eslint -c ./eslint.config.js ./src",
      "files": [
        "src/**/*.ts",
        "src/**/*.js",
        "eslint.config.js"
      ],
      "output": []
    },
    "lint:analyzer": {
      "command": "lit-analyzer src",
      "files": [
        "src/**/*.ts",
        "src/**/*.js",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "generate-manifest"
      ]
    },
    "lint:repo": {
      "command": "node ../../../tools/lint-changes/lint.changes.js",
      "files": [
        "**",
        "!dist/**",
        "!coverage/**",
        "!storybook-static/**"
      ],
      "output": []
    },
    "create-icon-spritesheet": {
      "command": "node create-icon-spritesheet.js",
      "files": [
        "icons/**",
        "create-icon-spritesheet.js"
      ],
      "output": [
        "src/icon/svg/**",
        "src/icon/icon-names.js"
      ]
    },
    "storybook": {
      "command": "build-storybook --output-dir ./storybook-static",
      "files": [
        ".storybook/**",
        "src/**/*.stories.ts",
        "src/**/*.stories.mdx",
        "vite.config.ts"
      ],
      "output": [
        "storybook-static/**"
      ],
      "dependencies": [
        "build"
      ]
    },
    "storybook:watch": {
      "command": "start-storybook -p 7789",
      "service": true
    },
    "prepublishonly": {
      "dependencies": [
        "ci"
      ]
    }
  }
}
