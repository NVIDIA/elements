    "./textarea": "./dist/textarea/index.js",
    "./textarea/index.js": "./dist/textarea/index.js",
    "./textarea/define.js": "./dist/textarea/define.js",
    "./toolbar": "./dist/toolbar/index.js",
    "./toolbar/index.js": "./dist/toolbar/index.js",
    "./toolbar/define.js": "./dist/toolbar/define.js",
    "./tooltip": "./dist/tooltip/index.js",
    "./tooltip/index.js": "./dist/tooltip/index.js",
