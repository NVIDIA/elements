  "typesVersions": {
    "*": {
      "*/define": [
        "dist/*/define.d.ts"
      ],
      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "pnpm": {
    "overrides": {
      "rollup-plugin-minify-html-literals": {
        "rollup@^0.65.2 || ^1.0.0 || ^2.0.0": "$rollup"
      }
    }
  },
  "dependencies": {
    "@floating-ui/dom": "1.4.5",
    "@lit-labs/motion": "^1.0.3",
    "composed-offset-position": "^0.0.4",
    "lit": "^2.7.6",
    "lit-html": "^2.7.5"
  },
  "optionalDependencies": {
    "@lit-labs/scoped-registry-mixin": "^1.0.1",
    "@webcomponents/scoped-custom-element-registry": "^0.0.9",
    "construct-style-sheets-polyfill": "^3.1.0",
    "element-internals-polyfill": "^1.3.5",
    "formdata-polyfill": "^4.0.10"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.8.3",
    "@lit-labs/virtualizer": "2.0.4",
    "@rollup/plugin-replace": "5.0.2",
    "@rollup/plugin-terser": "0.4.3",
    "@storybook/addon-docs": "7.1.1",
    "@storybook/addon-essentials": "7.1.1",
    "@storybook/addon-links": "7.1.1",
    "@storybook/addons": "7.1.1",
    "@storybook/blocks": "7.1.1",
    "@storybook/builder-vite": "7.1.1",
    "@storybook/channel-postmessage": "7.1.1",
    "@storybook/channel-websocket": "7.1.1",
    "@storybook/client-api": "7.1.1",
    "@storybook/core-common": "7.1.1",
    "@storybook/preview-api": "7.1.1",
    "@storybook/theming": "7.1.1",
    "@storybook/web-components": "7.1.1",
    "@storybook/web-components-vite": "7.1.1",
    "@typescript-eslint/eslint-plugin": "6.1.0",
    "@typescript-eslint/parser": "6.1.0",
    "@typescript/lib-dom": "npm:@types/web@0.0.104",
    "@vitest/browser": "0.34.1",
    "@vitest/coverage-istanbul": "0.34.1",
    "@vitest/utils": "0.34.1",
    "chart.js": "4.3.3",
    "emoji-picker-element": "1.18.3",
    "eslint": "8.45.0",
    "eslint-plugin-lit": "1.8.3",
    "eslint-plugin-lit-a11y": "4.1.0",
    "eslint-plugin-rulesdir": "0.2.2",
    "eslint-plugin-wc": "1.5.0",
    "fflate": "0.8.0",
    "glob": "8.0.3",
    "globals": "13.20.0",
    "lit-analyzer": "1.2.1",
    "playwright": "1.36.2",
    "postcss": "8.4.26",
    "postcss-csso": "6.0.1",
    "postcss-each": "1.1.0",
    "postcss-load-config": "4.0.1",
    "postcss-mixins": "9.0.4",
    "postcss-nested": "6.0.1",
    "prettier": "2.5.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "regenerator-runtime": "0.13.10",
    "rollup": "3.26.3",
    "rollup-plugin-minify-html-literals": "1.2.6",
    "storybook": "7.1.1",
    "style-dictionary": "3.8.0",
    "svgo": "3.0.2",
    "terser": "5.19.2",
    "ts-lit-plugin": "1.2.1",
    "typescript": "4.9.5",
    "vite": "4.4.9",
    "vite-plugin-dts": "3.5.1",
    "vitest": "0.34.1",
    "wireit": "0.10.0"
  },
  "publishConfig": {
    "registry": "https://artifactory.build.nvidia.com/artifactory/api/npm/elements-ui-npm/"
  },
  "wireit": {
    "dev": {
      "dependencies": [
        "build:watch",
        "storybook:watch"
      ]
    },
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "test",
        "test:coverage",
        "storybook",
        "demos"
      ]
    },
    "ci:nocache": {
      "command": "pnpm i && pnpm run ci",
      "dependencies": [
        "clean"
      ]
    },
    "build": {
      "command": "node_modules/vite/bin/vite.js build",
      "files": [
        "build/vscode-custom-data.js",
        "public/**",
        "src/**",
        "!src/**/*.stories.ts",
        "!src/**/*.stories.mdx",
        "!src/**/*.test.ts",
        "tokens/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "custom-elements-manifest.config.mjs"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "build:icons"
      ]
    },
    "build:watch": {
      "command": "vite build --mode watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "clean": {
      "command": "git clean -dfX"
    },
    "test": {
      "command": "PLAYWRIGHT_BROWSERS_PATH=.playwright node_modules/vitest/vitest.mjs run --bail=1",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "playwright",
        "build"
      ]
    },
    "test:coverage": {
      "command": "node -e \"if (!process.env.BAZEL_WORKSPACE){process.exit(1)}\" || PLAYWRIGHT_BROWSERS_PATH=.playwright node_modules/vitest/vitest.mjs run --coverage --threads=false --bail=1 --browser.api.port=63316",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/**"
      ],
      "dependencies": [
        "test",
        "playwright",
        "build"
      ]
    },
    "test:watch": {
      "command": "PLAYWRIGHT_BROWSERS_PATH=.playwright vitest --watch",
      "service": true,
      "dependencies": [
        "playwright"
      ]
    },
    "playwright": {
      "command": "PLAYWRIGHT_BROWSERS_PATH=.playwright node_modules/playwright/cli.js install chromium",
      "files": [
        "package.json"
      ],
      "output": [
        ".playwright/**"
      ]
    },
    "demos": {
      "command": "node -e \"if (!process.env.BAZEL_WORKSPACE){process.exit(1)}\" || npm run _demos",
      "files": [],
      "output": []
    },
    "_demos": {
      "dependencies": [
        "../demos/static:build",
        "../demos/typescript:build",
        "../demos/extensions:build",
        "../demos/nextjs:build"
      ]
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "lint:analyzer",
        "lint:repo"
      ]
    },
    "lint:eslint": {
      "command": "node_modules/eslint/bin/eslint.js -c ./eslint.config.js ./src",
      "files": [
        "build/eslint/*.cjs",
        "src/**/*.ts",
        "src/**/*.js",
        "eslint.config.js"
      ],
      "output": []
    },
    "lint:analyzer": {
      "command": "node -e \"if (!process.env.BAZEL_WORKSPACE){process.exit(1)}\" || node_modules/lit-analyzer/cli.js src --rules.no-incompatible-type-binding off",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": []
    },
    "lint:repo": {
      "command": "node -e \"if (!process.env.BAZEL_WORKSPACE){process.exit(1)}\" || node ../../../tools/lint-changes/lint.changes.js",
      "files": [
        "**",
        "!dist/**",
        "!coverage/**",
        "!storybook-build/**"
      ],
      "output": []
    },
    "build:icons": {
      "command": "node -e \"if (!process.env.BAZEL_WORKSPACE){process.exit(1)}\" || node ./build/icons.js",
      "clean": false,
      "files": [
        "src/icon/**",
        "!src/icon/icons.ts",
        "build/icons.js"
      ],
      "output": [
        "src/icon/icons.ts"
      ]
    },
    "storybook": {
      "command": "node_modules/storybook/index.js build --output-dir ./storybook-build",
      "files": [
        ".storybook/**",
        "src/**/*.stories.ts",
        "src/**/*.stories.mdx",
        "docs/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "storybook-build/**"
      ],
      "dependencies": [
        "test:coverage"
      ],
      "env": {
        "NODE_OPTIONS": "--openssl-legacy-provider"
      }
    },
    "storybook:watch": {
      "command": "node_modules/storybook/index.js dev --port 7777",
      "service": true,
      "env": {
        "NODE_OPTIONS": "--openssl-legacy-provider"
      }
    },
    "metrics": {
      "command": "node ./metrics/index.mjs",
      "files": [
        "metrics/index.mjs"
      ],
      "output": [
        "metrics/data.json"
      ],
      "dependencies": [
        "test:coverage"
      ]
    },
    "prepublishonly": {
      "dependencies": [
        "ci"
      ]
    }
  }
}
