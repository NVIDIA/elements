      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@floating-ui/dom": "1.6.1",
    "@nvidia-elements/forms": "workspace:*",
    "composed-offset-position": "^0.0.4",
    "lit": "catalog:",
    "lit-html": "catalog:"
  },
  "peerDependencies": {
    "@nvidia-elements/themes": "workspace:^"
  },
  "optionalDependencies": {
    "@lit-labs/scoped-registry-mixin": "catalog:",
    "@webcomponents/scoped-custom-element-registry": "catalog:",
    "construct-style-sheets-polyfill": "^3.1.0",
    "element-internals-polyfill": "^1.3.12",
    "formdata-polyfill": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@nvidia-elements/styles": "workspace:^",
    "@lit-labs/virtualizer": "catalog:",
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@nvidia-elements/snippets": "workspace:*",
    "@nvidia-elements/testing": "workspace:*",
    "@typescript/lib-dom": "npm:@types/web@0.0.169",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "cpy-cli": "catalog:",
    "eslint": "catalog:",
    "lit-analyzer": "2.0.3",
    "publint": "catalog:",
    "svgo": "3.0.2",
    "ts-lit-plugin": "2.0.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "publint",
        "test:axe",
        "test:ssr",
        "test:coverage",
        "test:visual"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "dev": {
      "command": "NODE_ENV=development vite build --watch",
      "service": true,
      "dependencies": [
        "build:icons",
        "build:snippets",
        "../themes:build",
        "../styles:build",
        "../internals/vite:ci"
      ]
    },
    "build": {
      "command": "NODE_ENV=production ELEMENTS_BUILD=true vite build",
      "files": [
        "public/**",
        "src/**",
        "!src/**/*.test.ts",
        "!src/**/*.test.lighthouse.ts",
        "!src/**/*.test.visual.ts",
        "!src/**/*.test.axe.ts",
        "!src/**/*.test.ssr.ts",
        "!src/**/*.snippets.html",
        "!src/icon/{server,icons}.ts",
        "!src/**/__screenshots__/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vite.bundle.ts",
        "custom-elements-manifest.config.mjs",
        "../labs/forms/dist/**/*.js"
      ],
      "output": [
        "dist/**",
        "!dist/inter.css",
        "!dist/inter.woff",
        "!dist/data.snippets.json"
      ],
      "dependencies": [
        "build:icons",
        "build:snippets",
        "../themes:build",
        "../styles:build",
        "../internals/vite:ci",
        {
          "script": "../labs/forms:build",
          "cascade": false
        }
      ]
    },
    "build:icons": {
      "command": "node ./build/icons.js",
      "clean": false,
      "files": [
        "src/icon/**",
        "!src/icon/{icons,server}.ts",
        "!src/**/__screenshots__/**",
        "build/icons.js"
      ],
      "output": [
        "src/icon/icons.ts",
        "src/icon/server.ts"
      ]
    },
    "build:snippets": {
      "command": "@nve-snippets",
      "files": [
        "src/**/*.snippets.html"
      ],
      "output": [
        "dist/data.snippets.json"
      ],
      "dependencies": [
        "../labs/snippets:ci"
      ]
    },
    "build:snippets:watch": {
      "command": "@nve-snippets --watch",
      "dependencies": [
        "../labs/snippets:ci"
      ]
    },
    "test": {
      "command": "playwright-lock 'vitest run'",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.ts",
        "tsconfig.json",
        "!src/**/__screenshots__/**",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "../testing:ci",
        "../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:coverage": {
      "command": "playwright-lock 'vitest run --coverage'",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.ts",
        "tsconfig.json",
        "!src/**/__screenshots__/**",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/unit/**"
      ],
      "dependencies": [
        "../testing:ci",
        "../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "test:lighthouse": {
      "command": "playwright-lock 'vitest run --config=vitest.lighthouse.ts'",
      "files": [
        "src/index.test.lighthouse.ts",
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.html",
        "vitest.lighthouse.ts"
      ],
      "output": [
        ".lighthouse"
      ],
      "dependencies": [
        "build",
        "../internals/vite:ci"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:visual": {
      "command": "playwright-lock 'vitest run --config=vitest.visual.ts'",
      "clean": false,
      "files": [
        "dist/**/*.js",
        "src/index.test.visual.ts",
        "src/**/*.test.visual.ts",
        "vitest.visual.html",
        "vitest.visual.ts"
      ],
      "output": [
        ".visual/*.png",
        "coverage/visual/**"
      ],
      "dependencies": [
        "../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ]
    },
    "test:axe": {
      "command": "playwright-lock 'vitest run --config=vitest.axe.ts'",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.axe.ts",
        "tsconfig.json",
        "vitest.axe.ts"
      ],
      "output": [
        "coverage/axe/**"
      ],
      "dependencies": [
        "../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:ssr": {
      "command": "playwright-lock 'vitest run --config=vitest.ssr.ts'",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.ssr.ts",
        "tsconfig.json",
        "vitest.ssr.ts",
        "../themes/dist/**/*.css"
      ],
      "output": [
        "coverage/ssr/**"
      ],
      "dependencies": [
        "../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        },
        {
          "script": "../themes:build",
          "cascade": false
        }
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "lint": {
      "dependencies": [
        "lint:eslint",
        "lint:analyzer"
      ]
    },
    "lint:eslint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js",
        "!src/icon/{server,icons}.ts",
        "!src/**/__screenshots__/**"
      ],
      "output": [],
      "dependencies": [
        "../internals/eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix"
    },
    "lint:analyzer": {
      "command": "lit-analyzer src/**/*.ts --strict --rules.no-unknown-slot off",
      "files": [
        "src/**/*.ts",
        "tsconfig.json",
        "!src/icon/{server,icons}.ts",
        "!src/**/__screenshots__/**"
      ],
      "output": []
    }
  }
}
