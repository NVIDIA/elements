{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "es2022",
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "typeRoots": ["./node_modules/@types"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/",
    "baseUrl": "./",
    "rootDir": "./",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "isolatedModules": true,
    "paths": {
      "@elements/elements": ["./src/index.js"],
      "@elements/elements/*": ["./src/*"],
      "@elements/elements/*.js": ["./src/*.js"],
      "elements-lighthouse": [".lighthouse/index.js"]
    },
    "plugins": [
      {
        "name": "ts-lit-plugin",
        "strict": true,
        "globalAttributes": ["mlv-text", "mlv-layout", "mlv-theme"],
        "rules": {
          "no-unknown-tag-name": "off",
          "no-unknown-attribute": "off",
          "no-missing-import": "off",
          "no-unknown-property": "off"
        }
      }
    ]
  },
  "include": ["src/**/*.ts"]
}
