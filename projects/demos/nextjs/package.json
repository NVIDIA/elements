{
  "name": "my-app",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wireit",
    "build": "wireit",
    "start": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "@lit-labs/nextjs": "0.1.2",
    "@lit-labs/react": "2.0.0",
    "@elements/elements": "workspace:*",
    "@types/node": "20.4.7",
    "@types/react": "18.2.18",
    "@types/react-dom": "18.2.7",
    "next": "13.4.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "typescript": "5.1.6"
  },
  "wireit": {
    "dev": {
      "command": "next dev",
      "dependencies": [
        "../../elements:build"
      ]
    },
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "lint": {
      "command": "next lint"
    },
    "start": {
      "command": "next start",
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "next build",
      "dependencies": [
        "../../elements:build"
      ],
      "output": [
        ".next/**"
      ],
      "files": [
        "src/**",
        "package.json",
        "next.config.cjs",
        "tsconfig.json"
      ]
    }
  }
}
