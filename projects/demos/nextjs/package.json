{
  "name": "my-app",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "start": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "@lit-labs/nextjs": "0.1.4",
    "@elements/elements": "workspace:../../elements",
    "@elements/elements-react": "*",
    "@types/node": "20.4.7",
    "@types/react": "18.2.18",
    "@types/react-dom": "18.2.7",
    "next": "13.4.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "typescript": "5.3.3",
    "wireit": "0.14.1"
  },
  "wireit": {
    "dev": {
      "command": "next dev",
      "dependencies": [
        "../../elements-react:build"
      ]
    },
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "next lint"
    },
    "start": {
      "command": "next start",
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "next build",
      "dependencies": [
        "../../elements-react:build"
      ],
      "output": [
        ".next/**"
      ],
      "files": [
        "src/**",
        "package.json",
        "next.config.cjs",
        "tsconfig.json"
      ]
    }
  }
}
