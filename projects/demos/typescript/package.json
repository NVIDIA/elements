{
  "name": "typescript-elements-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "service": true
    },
    "build": {
      "command": "vite build",
      "files": [
        "index.html",
        "src/**",
        "tsconfig.json",
        "vite.config.ts",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    },
    "preview": {
      "command": "vite preview",
      "dependencies": [
        "build"
      ]
    }
  },
  "dependencies": {
    "@elements/elements": "workspace:../../elements"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.0.10",
    "wireit": "0.14.3"
  }
}
