{
  "name": "typescript-elements-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "build": {
      "command": "tsc && vite build",
      "files": ["index.html", "src/**", "tsconfig.json", "vite.config.ts", "package.json"],
      "output": ["dist"],
      "dependencies": ["../../elements:build"]
    },
    "preview": {
      "command": "vite preview",
      "dependencies": [
        "build"
      ]
    }
  },
  "dependencies": {
    "@elements/elements": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.2.2",
    "vite": "4.5.0",
    "vite-plugin-static-copy": "0.17.0"
  }
}
