{
  "name": "extensions-elements-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "wireit",
    "preview": "vite preview"
  },
  "wireit": {
    "build": {
      "command": "tsc && vite build",
      "files": ["index.html", "vite.config.ts", "package.json"],
      "output": ["dist"],
      "dependencies": ["../../elements:build"]
    }
  },
  "dependencies": {
    "@elements/elements": "workspace:*"
  },
  "devDependencies": {
    "typescript": "4.9.4",
    "vite": "4.0.2",
    "vite-plugin-static-copy": "0.13.0"
  }
}
