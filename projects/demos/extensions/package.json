{
  "name": "extensions-elements-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./index.js": "./dist/index.js",
    "./login": "./dist/login/index.js",
    "./login/index.js": "./dist/login/index.js",
    "./login/define.js": "./dist/login/define.js"
  },
  "sideEffects": [
    "./**/define.js"
  ],
  "typesVersions": {
    "*": {
      "*/define": [
        "dist/*/define.d.ts"
      ],
      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "build:watch": "wireit",
    "test": "wireit",
    "test:watch": "wireit",
    "storybook": "wireit",
    "storybook:watch": "wireit"
  },
  "dependencies": {
    "@lit-labs/scoped-registry-mixin": "^1.0.3",
    "@elements/elements": "workspace:../../elements",
    "@webcomponents/scoped-custom-element-registry": "^0.0.9",
    "lit": "^3.1.0",
    "lit-html": "^3.1.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "8.9.0",
    "@storybook/addon-docs": "7.1.1",
    "@storybook/addon-essentials": "7.1.1",
    "@storybook/addon-links": "7.1.1",
    "@storybook/addons": "7.1.1",
    "@storybook/blocks": "7.1.1",
    "@storybook/builder-vite": "7.1.1",
    "@storybook/channel-postmessage": "7.1.1",
    "@storybook/channel-websocket": "7.1.1",
    "@storybook/client-api": "7.1.1",
    "@storybook/core-common": "7.1.1",
    "@storybook/preview-api": "7.1.1",
    "@storybook/theming": "7.1.1",
    "@storybook/web-components": "7.1.1",
    "@storybook/web-components-vite": "7.1.1",
    "@vitest/browser": "1.1.0",
    "glob": "8.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "storybook": "7.1.1",
    "typescript": "5.3.3",
    "vite": "5.0.10",
    "vite-plugin-dts": "3.7.0",
    "vitest": "1.1.0"
  },
  "wireit": {
    "dev": {
      "dependencies": [
        "build:watch",
        "storybook:watch"
      ]
    },
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "tsc && vite build",
      "dependencies": [
        "../../elements:build"
      ],
      "output": [
        "dist/**"
      ],
      "files": [
        "src/**",
        "!src/**/*.stories.ts",
        "!src/**/*.stories.mdx",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ]
    },
    "build:watch": {
      "command": "vite build --mode watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "test": {
      "command": "vitest run",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "build"
      ]
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "storybook": {
      "command": "storybook-build --output-dir ./storybook-build",
      "files": [
        ".storybook/**",
        "src/**/*.stories.ts",
        "src/**/*.stories.mdx",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "storybook-build/**"
      ],
      "dependencies": [
        "build"
      ]
    },
    "storybook:watch": {
      "command": "storybook dev",
      "service": true
    }
  }
}
