{
  "name": "buildless-elements-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wireit"
  },
  "wireit": {
    "dev": {
      "command": "http-server",
      "service": true,
      "files": [
        "index.html",
        "package.json"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    }
  },
  "dependencies": {
    "@floating-ui/dom": "1.2.5",
    "@floating-ui/core": "1.2.5",
    "@lit-labs/motion": "1.0.3",
    "@lit/reactive-element": "1.6.1",
    "@elements/elements": "workspace:*",
    "lit": "2.7.0",
    "lit-element": "3.3.0",
    "lit-html": "2.7.0"
  },
  "devDependencies": {
    "http-server": "14.1.1"
  }
}
