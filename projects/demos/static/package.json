{
  "name": "static-elements-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "vite build",
      "files": ["index.html", "vite.config.ts", "package.json"],
      "output": ["dist"],
      "dependencies": ["../../elements:build"]
    },
    "preview": {
      "command": "vite preview",
      "dependencies": [
        "build"
      ]
    }
  },
  "dependencies": {
    "@elements/elements": "workspace:../../elements"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.0.10"
  }
}
