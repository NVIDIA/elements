{
  "name": "storybook-workspace",
  "version": "0.0.0",
  "type": "module",
  "customElements": "custom-elements.json",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/testing": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@nvidia-elements/behaviors-alpine": "workspace:*",
    "@nvidia-elements/brand": "workspace:*",
    "@nvidia-elements/code": "workspace:*",
    "@nvidia-elements/forms": "workspace:*",
    "@nvidia-elements/monaco": "workspace:*",
    "@nve-internals/elements-api": "workspace:*",
    "html-format": "1.1.7",
    "lit": "catalog:",
    "showdown": "2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@nve-internals/eslint": "workspace:*",
    "@storybook/core-events": "8.5.0",
    "@storybook/addon-docs": "8.5.0",
    "@storybook/addon-essentials": "8.5.0",
    "@storybook/addon-links": "8.5.0",
    "@storybook/blocks": "8.5.0",
    "@storybook/components": "8.5.0",
    "@storybook/icons": "1.3.0",
    "@storybook/manager-api": "8.5.0",
    "@storybook/preview-api": "8.5.0",
    "@storybook/theming": "8.5.0",
    "@storybook/web-components": "8.5.0",
    "@storybook/web-components-vite": "8.5.0",
    "eslint": "catalog:",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "storybook": "8.5.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "dev": {
      "command": "storybook dev --port 7777",
      "service": true,
      "clean": false,
      "dependencies": [
        "../elements:build",
        "../labs/code:build",
        "../labs/brand:build",
        "../labs/forms:build",
        "../monaco:build",
        "../styles:build",
        "../themes:build",
        "../starters/lit-library:build",
        "../internals/elements-api:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "storybook build --output-dir ./dist",
      "files": [
        ".storybook/**",
        "src/**",
        "package.json",
        "tsconfig.json",
        "../**/coverage/size/index.html",
        "../elements/src/**/*.mdx",
        "../elements/src/**/*.stories.ts",
        "../labs/code/docs/**/*.mdx",
        "../labs/code/docs/**/*.stories.ts",
        "../monaco/docs/**/*.mdx",
        "../monaco/docs/**/*.stories.ts",
        "../styles/docs/**/*.mdx",
        "../styles/docs/**/*.stories.ts",
        "../testing/docs/**/*.mdx",
        "../testing/docs/**/*.stories.ts",
        "../themes/docs/**/*.mdx",
        "../themes/docs/**/*.stories.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../elements:build",
        "../labs/code:build",
        "../monaco:build",
        "../styles:build",
        "../themes:build",
        "../starters/lit-library:build",
        "../internals/elements-api:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../internals/eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix"
    }
  }
}
