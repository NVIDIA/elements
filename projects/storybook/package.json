{
  "name": "storybook-workspace",
  "version": "0.0.0",
  "type": "module",
  "customElements": "custom-elements.json",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:@elements/elements@*",
    "@nvidia-elements/core-react": "workspace:@elements/elements-react@*",
    "@nvidia-elements/testing": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@nvidia-elements/behaviors-alpine": "workspace:*",
    "@nvidia-elements/code": "workspace:*",
    "fflate": "0.8.1",
    "html-format": "1.1.2",
    "lit": "3.1.3",
    "showdown": "2.1.0"
  },
  "devDependencies": {
    "@internals/eslint": "workspace:*",
    "@storybook/core-events": "8.0.0",
    "@storybook/addon-docs": "8.0.0",
    "@storybook/addon-essentials": "8.0.0",
    "@storybook/addon-links": "8.0.0",
    "@storybook/addon-mdx-gfm": "8.0.0",
    "@storybook/blocks": "8.0.0",
    "@storybook/theming": "8.0.0",
    "@storybook/web-components": "8.0.0",
    "@storybook/web-components-vite": "8.0.0",
    "eslint": "9.6.0",
    "storybook": "8.0.0",
    "typescript": "5.3.3",
    "vite": "5.3.3"
  },
  "wireit": {
    "dev": {
      "command": "storybook dev --port 7777",
      "service": true,
      "clean": false
    },
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "build": {
      "command": "storybook build --output-dir ./dist",
      "files": [
        ".storybook/**",
        "src/**",
        "package.json",
        "tsconfig.json",
        "../elements/src/**/*.mdx",
        "../elements/src/**/*.stories.ts",
        "../elements-react/docs/**/*.mdx",
        "../elements-react/docs/**/*.stories.tsx",
        "../labs/code/docs/**/*.mdx",
        "../labs/code/docs/**/*.stories.ts",
        "../labs/testing-lighthouse/docs/**/*.mdx",
        "../labs/testing-lighthouse/docs/**/*.stories.ts",
        "../testing/docs/**/*.mdx",
        "../testing/docs/**/*.stories.ts",
        "../themes/docs/**/*.mdx",
        "../themes/docs/**/*.stories.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../elements:build",
        "../labs/code:build",
        "../starters/lit-library:ci"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js ./src/**/*.ts",
      "files": [
        "src/**/*.ts",
        "src/**/*.js",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../internals/eslint:ci"
      ]
    }
  }
}
