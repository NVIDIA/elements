{
  "name": "storybook-workspace",
  "version": "0.0.0",
  "type": "module",
  "customElements": "custom-elements.json",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/testing": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@nvidia-elements/behaviors-alpine": "workspace:*",
    "@nvidia-elements/brand": "workspace:*",
    "@nvidia-elements/code": "workspace:*",
    "@nvidia-elements/forms": "workspace:*",
    "@nvidia-elements/monaco": "workspace:*",
    "@internals/patterns": "workspace:*",
    "lit": "catalog:"
  },
  "devDependencies": {
    "@storybook/addon-links": "9.0.15",
    "@storybook/addon-docs": "9.0.15",
    "@storybook/web-components-vite": "9.0.15",
    "@storybook/web-components": "9.0.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "storybook": "9.0.15",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "storybook dev --port 7777",
      "service": true,
      "clean": false,
      "dependencies": [
        "../elements:build",
        "../labs/code:build",
        "../labs/brand:build",
        "../labs/forms:build",
        "../monaco:build",
        "../styles:build",
        "../themes:build",
        "../starters/lit-library:build",
        "../internals/patterns:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "storybook build --output-dir ./dist",
      "files": [
        ".storybook/**",
        "src/**",
        "package.json",
        "tsconfig.json",
        "../**/coverage/size/index.html",
        "../elements/src/**/*.stories.ts",
        "../labs/code/docs/**/*.stories.ts",
        "../monaco/docs/**/*.stories.ts",
        "../styles/docs/**/*.stories.ts",
        "../testing/docs/**/*.stories.ts",
        "../themes/docs/**/*.stories.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../elements:build",
        "../labs/code:build",
        "../monaco:build",
        "../styles:build",
        "../themes:build",
        "../starters/lit-library:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    }
  }
}
