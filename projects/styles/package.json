{
  "name": "@nvidia-elements/styles",
  "version": "1.6.0",
  "description": "Base global styles for Elements",
  "homepage": "https://NVIDIA.github.io/elements/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NVIDIA/elements.git"
  },
  "type": "module",
  "contributes": {
    "html": {
      "customData": [
        "./dist/data.html.json"
      ]
    }
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./CHANGELOG.md": "./CHANGELOG.md",
    "./data.html.json": "./dist/data.html.json",
    "./layout.css": "./dist/layout.css",
    "./responsive.css": "./dist/responsive.css",
    "./typography.css": "./dist/typography.css",
    "./view-transitions.css": "./dist/view-transitions.css",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "test:lighthouse": "wireit",
    "test:visual": "wireit"
  },
  "peerDependencies": {
    "@nvidia-elements/themes": "workspace:^"
  },
  "devDependencies": {
    "@nvidia-elements/themes": "workspace:*",
    "@nvidia-elements/testing": "workspace:*",
    "@internals/vite": "workspace:*",
    "@vitest/browser": "catalog:",
    "lit": "catalog:",
    "postcss": "8.4.31",
    "postcss-each": "1.1.0",
    "postcss-load-config": "4.0.1",
    "postcss-mixins": "9.0.4",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "publint",
        "test:visual"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "dev": {
      "dependencies": [
        "build:watch",
        "../storybook:dev"
      ]
    },
    "build": {
      "command": "NODE_ENV=production vite build && node ./build/metadata.js",
      "files": [
        "src/**",
        "!src/**/*.test.lighthouse.ts",
        "!src/**/*.test.visual.ts",
        "package.json",
        "vite.config.ts",
        "postcss.config.cjs"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../themes:build",
        "../internals/vite:ci"
      ]
    },
    "build:watch": {
      "command": "vite build --watch",
      "service": true,
      "dependencies": []
    },
    "test:lighthouse": {
      "command": "playwright-lock 'vitest run --config=vitest.lighthouse.ts'",
      "files": [
        "src/index.test.lighthouse.ts",
        "src/**/*.test.lighthouse.ts",
        "vitest.lighthouse.html",
        "vitest.lighthouse.ts"
      ],
      "output": [
        ".lighthouse"
      ],
      "dependencies": [
        "build",
        "../internals/vite:ci"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "test:visual": {
      "command": "playwright-lock 'vitest run --config=vitest.visual.ts'",
      "clean": false,
      "files": [
        "src/index.test.visual.ts",
        "src/**/*.test.visual.ts",
        "vitest.visual.html",
        "vitest.visual.ts"
      ],
      "output": [
        ".visual/*.png"
      ],
      "dependencies": [
        "build"
      ]
    }
  }
}
