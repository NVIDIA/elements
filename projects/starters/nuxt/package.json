{
  "name": "nuxt-starter",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "wireit",
    "ci": "wireit",
    "lint": "wireit",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "nuxt": "4.3.1",
    "vue": "3.5.28",
    "vue-router": "5.0.2"
  },
  "devDependencies": {
    "@nvidia-elements/lint": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "3.2.4"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "build": {
      "command": "nuxi typecheck && nuxt build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "app/**",
        "src/**",
        "env.d.ts",
        "package.json",
        "tsconfig.json",
        "nuxt.config.ts"
      ],
      "output": [
        ".output/public/**",
        ".output/server/**"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../lint:build"
      ]
    }
  }
}
