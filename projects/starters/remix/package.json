{
  "name": "remix-starter",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "start": "wireit"
  },
  "dependencies": {
    "@lit-labs/ssr-react": "catalog:",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@remix-run/node": "2.15.2",
    "@remix-run/react": "2.15.2",
    "isbot": "5.1.17",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@remix-run/serve": "2.15.2",
    "@remix-run/dev": "2.15.2",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "wireit": {
    "dev": {
      "command": "remix vite:dev",
      "dependencies": [
        "../../elements:build"
      ]
    },
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "start": {
      "command": "remix-serve build/server/index.js",
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "remix vite:build",
      "dependencies": [
        "../../elements:build"
      ],
      "output": [
        "build/**"
      ],
      "files": [
        "app/**",
        "public/**",
        "package.json",
        "vite.config.ts",
        "tsconfig.json"
      ]
    }
  }
}
