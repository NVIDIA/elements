{
  "name": "starters",
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "build": "wireit"
  },
  "dependencies": {
    "@pnpm/exportable-manifest": "7.0.3",
    "@pnpm/read-project-manifest": "6.0.6",
    "@pnpm/workspace.read-manifest": "2.2.0",
    "@pnpm/catalogs.config": "0.1.0",
    "archiver": "7.0.1",
    "glob": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "node ./index.js",
      "files": [
        "./index.js"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "./angular:build",
        "./buildless:build",
        "./eleventy:build",
        "./lit-library:build",
        "./mpa:build",
        "./nextjs:build",
        "./nextjs-react-18:build",
        "./react:build",
        "./react-18:build",
        "./remix:build",
        "./remix-react-18:build",
        "./scoped-registry:build",
        "./solidjs:build",
        "./typescript:build",
        "./vue:build"
      ]
    }
  }
}
