{
  "name": "importmaps-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "build": "wireit",
    "dev": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "node build.js",
      "files": [
        "../../core/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/index.html",
        "build.js"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        {
          "script": "../../core:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        }
      ]
    },
    "dev": {
      "command": "cd dist && http-server",
      "service": true,
      "files": [
        "index.html",
        "package.json"
      ],
      "dependencies": [
        "ci"
      ]
    }
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@lit/reactive-element": "catalog:",
    "lit": "catalog:",
    "lit-html": "catalog:",
    "lit-element": "catalog:"
  },
  "devDependencies": {
    "http-server": "14.1.1"
  }
}
