{
  "name": "solidjs-starter",
  "version": "0.0.0",
  "description": "",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "license": "MIT",
  "devDependencies": {
    "solid-devtools": "0.29.3",
    "typescript": "5.3.3",
    "vite": "5.3.3",
    "vite-plugin-solid": "2.10.1"
  },
  "dependencies": {
    "@elements/elements": "workspace:*",
    "solid-js": "1.8.15"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "../../elements:build"
      ]
    },
    "build": {
      "command": "vite build",
      "dependencies": [
        "../../elements:build"
      ],
      "output": [
        ".next/**"
      ],
      "files": [
        "src/**",
        "package.json"
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true
    }
  }
}
