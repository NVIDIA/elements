{
  "name": "solidjs-starter",
  "version": "0.0.0",
  "description": "",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "license": "MIT",
  "devDependencies": {
    "solid-devtools": "0.31.5",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-solid": "2.11.0"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "solid-js": "1.9.3"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "../../elements:build"
      ]
    },
    "build": {
      "command": "vite build",
      "dependencies": [
        "../../elements:build"
      ],
      "output": [
        ".next/**"
      ],
      "files": [
        "src/**",
        "package.json"
      ],
      "env": {
        "PAGES_SITE_PREFIX": {
          "external": true,
          "default": ""
        }
      }
    },
    "preview": {
      "command": "vite preview",
      "service": true
    }
  }
}
