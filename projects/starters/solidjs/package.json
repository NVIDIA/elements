{
  "name": "solidjs-starter",
  "version": "0.0.0",
  "description": "",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "license": "MIT",
  "devDependencies": {
    "solid-devtools": "0.34.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-solid": "2.11.7"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "solid-js": "1.9.3"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "../../elements:build"
      ]
    },
    "build": {
      "command": "vite build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "package.json"
      ],
      "output": [
        ".next/**"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    }
  }
}
