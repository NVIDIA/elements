{
  "name": "angular-starter",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "ci": "wireit",
    "dev": "wireit",
    "start": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "dev": {
      "command": "ng serve",
      "service": true
    },
    "start": {
      "command": "ng serve",
      "service": true
    },
    "build": {
      "command": "ng build --base-href ${PAGES_BASE_URL}starters/angular/",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "angular.json",
        "tsconfig.json",
        "tsconfig.app.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../labs/lint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../../labs/lint:ci"
      ]
    }
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@angular/common": "20.1.0",
    "@angular/compiler": "20.1.0",
    "@angular/core": "20.1.0",
    "@angular/forms": "20.1.0",
    "@angular/platform-browser": "20.1.0",
    "@angular/router": "20.1.0",
    "rxjs": "7.8.0",
    "tslib": "2.3.0"
  },
  "devDependencies": {
    "@angular/build": "20.1.0",
    "@angular/cli": "20.1.0",
    "@angular/compiler-cli": "20.1.0",
    "@nvidia-elements/lint": "workspace:*",
    "@types/jasmine": "5.1.0",
    "eslint": "catalog:",
    "jasmine-core": "5.8.0",
    "karma": "6.4.0",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.0",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "typescript": "catalog:"
  }
}
