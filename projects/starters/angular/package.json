{
  "name": "angular-starter",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "ci": "wireit",
    "dev": "wireit",
    "start": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "dev": {
      "command": "ng serve",
      "service": true
    },
    "start": {
      "command": "ng serve",
      "service": true
    },
    "build": {
      "command": "ng build --base-href ${PAGES_BASE_URL}starters/angular/",
      "files": [
        "../../core/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "angular.json",
        "tsconfig.json",
        "tsconfig.app.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        {
          "script": "../../core:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../../lint:build"
      ]
    }
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@angular/common": "21.0.8",
    "@angular/compiler": "21.0.8",
    "@angular/core": "21.0.8",
    "@angular/forms": "21.0.8",
    "@angular/platform-browser": "21.0.8",
    "@angular/router": "21.0.8",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.0.5",
    "@angular/cli": "21.0.5",
    "@angular/compiler-cli": "21.0.8",
    "@nvidia-elements/lint": "workspace:*",
    "eslint": "catalog:",
    "jsdom": "27.1.0",
    "typescript": "5.9.3",
    "vitest": "catalog:"
  }
}
