{
  "name": "vue-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "vite",
    "preview": "vite preview"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "vue-tsc --build --force && vite build",
      "files": [
        "src/**",
        "public/**",
        "vite.config.ts",
        "teconfig.json"
      ],
      "output": [
        "./dist/**"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    }
  },
  "dependencies": {
    "@elements/elements": "workspace:*",
    "vue": "3.4.15"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.0.3",
    "@vue/tsconfig": "0.5.1",
    "typescript": "5.3.3",
    "vite": "5.2.9",
    "vue-tsc": "1.8.27"
  }
}
