{
  "name": "vue-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "service": true,
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "vue-tsc --build --force && vite build",
      "files": [
        "src/**",
        "public/**",
        "vite.config.ts",
        "teconfig.json"
      ],
      "output": [
        "./dist/**"
      ],
      "dependencies": [
        "../../elements:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    }
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "vue": "3.4.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.2.1",
    "@vue/tsconfig": "0.5.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "2.0.29"
  }
}
