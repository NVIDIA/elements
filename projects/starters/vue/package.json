{
  "name": "vue-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "build": "wireit",
    "dev": "wireit",
    "preview": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "vue": "3.5.28"
  },
  "devDependencies": {
    "@nvidia-elements/lint": "workspace:*",
    "@tsconfig/node20": "20.1.6",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/tsconfig": "0.8.1",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "3.2.4"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "dev": {
      "command": "vite",
      "service": true
    },
    "build": {
      "command": "vue-tsc --build --force && vite build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "public/**",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.app.json",
        "tsconfig.node.json",
        "env.d.ts"
      ],
      "output": [
        "./dist/**"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../../lint:build"
      ]
    }
  }
}
