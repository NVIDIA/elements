{
  "name": "bundles-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "service": true
    },
    "build": {
      "command": "vite build",
      "files": [
        "../../elements/dist/bundles/index.js",
        "../../elements/dist/bundles/index.css",
        "index.html",
        "vite.config.ts",
        "package.json"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        }
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    }
  }
}
