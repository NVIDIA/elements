{
  "name": "bundles-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "service": true
    },
    "build": {
      "command": "vite build",
      "files": [
        "index.html",
        "vite.config.ts",
        "package.json"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    }
  }
}
