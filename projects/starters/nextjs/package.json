{
  "name": "nextjs-starter",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "start": "wireit",
    "build": "wireit",
    "preview": "wireit",
    "lint": "wireit"
  },
  "dependencies": {
    "@lit-labs/nextjs": "0.2.4",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "next": "15.5.3"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "preview": {
      "command": "cd dist && pnpm exec vite preview --base=elements/starters/nextjs",
      "dependencies": [
        "build"
      ]
    },
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "next lint"
    },
    "start": {
      "command": "next start",
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "next dev",
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "command": "next build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "package.json",
        "next.config.mjs",
        "tsconfig.json"
      ],
      "output": [
        ".next/**",
        "dist/**"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    }
  }
}
