{
  "name": "react-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@nvidia-elements/lint": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "4.6.0",
    "eslint": "catalog:",
    "vite": "catalog:"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "lint"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "../../elements:build"
      ]
    },
    "build": {
      "command": "vite build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../labs/lint:build"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../../labs/lint:build"
      ]
    }
  }
}
