{
  "name": "lit-library-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./login": {
      "types": "./dist/login/index.d.ts",
      "default": "./dist/login/index.js"
    },
    "./login/index.js": {
      "types": "./dist/login/index.d.ts",
      "default": "./dist/login/index.js"
    },
    "./login/define.js": {
      "types": "./dist/login/define.d.ts",
      "default": "./dist/login/define.js"
    }
  },
  "sideEffects": [
    "./**/define.js"
  ],
  "typesVersions": {
    "*": {
      "*/define": [
        "dist/*/define.d.ts"
      ],
      "*/define.js": [
        "dist/*/define.d.ts"
      ],
      "*/index.js": [
        "dist/*/index.d.ts"
      ],
      "*": [
        "dist/*/index.d.ts"
      ]
    }
  },
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "build:watch": "wireit",
    "test": "wireit",
    "test:watch": "wireit"
  },
  "dependencies": {
    "lit": "catalog:"
  },
  "peerDependencies": {
    "@nvidia-elements/core": "workspace:*"
  },
  "devDependencies": {
    "@nve-internals/vite": "workspace:*",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "@nvidia-elements/testing": "workspace:*",
    "@rollup/plugin-terser": "catalog:",
    "@vitest/browser": "catalog:",
    "glob": "catalog:",
    "rollup-plugin-minify-html-literals": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "wireit": {
    "dev": {
      "command": "vite",
      "dependencies": [
        "build"
      ]
    },
    "ci": {
      "dependencies": [
        "build",
        "test"
      ]
    },
    "build": {
      "command": "NODE_ENV=production tsc -p tsconfig.lib.json && vite build",
      "dependencies": [
        {
          "script": "../../elements:build",
          "cascade": false
        }
      ],
      "output": [
        "dist/**"
      ],
      "files": [
        "../../elements/dist/**/*.js",
        "src/**",
        "!src/**/*.stories.ts",
        "!src/**/*.test.ts",
        "!src/**/*.mdx",
        "package.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ]
    },
    "build:watch": {
      "command": "vite build --mode watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "test": {
      "command": "playwright-lock 'vitest run'",
      "files": [
        "src/**/*.test.ts",
        "tsconfig.json",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "build",
        "../../testing:ci"
      ]
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    }
  }
}
