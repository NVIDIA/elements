{
  "name": "static-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "wireit",
    "preview": "wireit"
  },
  "dependencies": {
    "@elements/elements": "workspace:*",
    "@nvidia-elements/themes": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.2.9"
  },
  "wireit": {
    "build": {
      "command": "vite build",
      "files": [
        "index.html",
        "vite.config.ts",
        "package.json"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "../../elements:build"
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true,
      "dependencies": [
        "build"
      ]
    }
  }
}
