{
  "name": "eleventy-starter",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "pnpm exec eleventy --serve --port=8082",
      "service": true,
      "dependencies": [
        "build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "pnpm exec eleventy",
      "files": [
        "src",
        "assets",
        "./eleventy.config.js"
      ],
      "output": [
        "_site/**"
      ],
      "dependencies": [
        "clean",
        "../../elements:build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "preview": {
      "command": "pnpm run build && vite preview --base=$PAGES_BASE_URL",
      "service": true,
      "files": [
        "src",
        "assets",
        "./eleventy.config.js"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/starters/eleventy/"
        }
      }
    },
    "clean": {
      "command": "rm -rf dist && rm -rf _site",
      "files": [],
      "output": [],
      "dependencies": []
    }
  },
  "devDependencies": {
    "@11ty/eleventy": "3.0.1-alpha.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.0",
    "@11ty/eleventy-plugin-vite": "6.0.0",
    "@lit-labs/eleventy-plugin-lit": "1.0.3",
    "@lit-labs/ssr-client": "catalog:",
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "markdown-it": "14.1.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
