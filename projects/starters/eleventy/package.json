{
  "name": "eleventy-starter",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*"
  },
  "devDependencies": {
    "@11ty/eleventy": "catalog:",
    "@11ty/eleventy-plugin-syntaxhighlight": "catalog:",
    "@11ty/eleventy-plugin-vite": "catalog:",
    "@lit-labs/eleventy-plugin-lit": "catalog:",
    "@lit-labs/ssr-client": "catalog:",
    "markdown-it": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "pnpm exec eleventy --serve --port=8082",
      "service": true,
      "dependencies": [
        "build"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "build": {
      "command": "pnpm exec eleventy",
      "files": [
        "../../elements/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src",
        "assets",
        "./eleventy.config.js"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "clean",
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/"
        }
      }
    },
    "preview": {
      "command": "pnpm run build && vite preview --base=$PAGES_BASE_URL",
      "service": true,
      "files": [
        "src",
        "assets",
        "./eleventy.config.js"
      ],
      "env": {
        "PAGES_BASE_URL": {
          "external": true,
          "default": "/elements/preview/starters/eleventy/"
        }
      }
    },
    "clean": {
      "command": "rm -rf dist",
      "files": [],
      "output": [],
      "dependencies": []
    }
  }
}
