{
  "name": "react-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "wireit",
    "dev": "wireit",
    "build": "wireit",
    "preview": "wireit"
  },
  "dependencies": {
    "@nvidia-elements/core": "workspace:*",
    "@nvidia-elements/core-react": "workspace:*",
    "@nvidia-elements/styles": "workspace:*",
    "@nvidia-elements/themes": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.6.0",
    "vite": "catalog:"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "../../elements-react:build"
      ]
    },
    "build": {
      "command": "vite build",
      "files": [
        "../../elements/dist/**/*.js",
        "../../elements-react/dist/**/*.js",
        "../../styles/dist/**/*.css",
        "../../themes/dist/**/*.css",
        "src/**",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        {
          "script": "../../elements-react:build",
          "cascade": false
        },
        {
          "script": "../../elements:build",
          "cascade": false
        },
        {
          "script": "../../styles:build",
          "cascade": false
        },
        {
          "script": "../../themes:build",
          "cascade": false
        }
      ]
    },
    "preview": {
      "command": "vite preview",
      "service": true
    }
  }
}
