{
  "name": "@nvidia-elements/testing-lighthouse",
  "version": "0.0.0",
  "type": "module",
  "description": "Lighthouse Utilities for Vite",
  "scripts": {
    "ci": "wireit",
    "lint": "wireit",
    "build": "wireit"
  },
  "files": [
    "README.md",
    "package.json",
    "src/**/*"
  ],
  "dependencies": {
    "glob": "10.3.10",
    "lighthouse": "11.4.0",
    "playwright": "1.44.0",
    "vite": "5.3.3",
    "vite-plugin-virtual-html": "1.1.19"
  },
  "devDependencies": {
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@types/node": "20.14.2",
    "eslint": "9.6.0",
    "typescript": "5.3.3",
    "vitest": "2.0.3"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite-setup": {
      "types": "./dist/vite-setup.d.ts",
      "default": "./dist/vite-setup.js"
    },
    "./vite-setup.js": {
      "types": "./dist/vite-setup.d.ts",
      "default": "./dist/vite-setup.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./vite.js": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    }
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build"
      ]
    },
    "build": {
      "clean": false,
      "command": "vite build",
      "files": [
        "src/**",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist"
      ],
      "dependencies": [
        "../../internals/vite:ci"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js ./src/**/*.ts",
      "files": [
        "eslint.config.js",
        "src/**/*.ts"
      ],
      "output": [],
      "dependencies": [
        "../../internals/eslint:ci"
      ]
    }
  }
}
