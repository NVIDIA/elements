{
  "name": "@nvidia-elements/cli",
  "version": "0.10.7",
  "description": "Command-line interface for Elements development and tooling, providing interactive prompts, project scaffolding, and integration with AI assistants via Model Context Protocol.",
  "type": "module",
  "bin": {
    "nve": "./dist/index.js",
    "nve-mcp": "./dist/mcp/index.js",
    "nve-setup": "./dist/setup/index.js"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "dist/**/*"
  ],
  "scripts": {
    "dev": "wireit",
    "ci": "wireit",
    "build": "wireit",
    "lint": "wireit",
    "test": "wireit",
    "test:watch": "wireit",
    "test:coverage": "wireit",
    "nve:install": "test -n \"$CI\" || pnpm link --global",
    "nve:uninstall": "pnpm uninstall --global @nvidia-elements/cli"
  },
  "dependencies": {
    "@nvidia-elements/lint": "workspace:^",
    "@inquirer/prompts": "8.3.0",
    "semver": "7.7.4",
    "@modelcontextprotocol/sdk": "1.27.1",
    "adm-zip": "0.5.16",
    "archiver": "7.0.1",
    "glob": "catalog:",
    "marked": "17.0.4",
    "marked-terminal": "7.3.0",
    "ora": "9.3.0",
    "publint": "catalog:",
    "yargs": "18.0.0",
    "open": "11.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@internals/tools": "workspace:*",
    "@internals/eslint": "workspace:*",
    "@internals/vite": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "7.7.1",
    "@types/yargs": "17.0.35",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "lint",
        "build",
        "publint",
        "test:coverage"
      ]
    },
    "publint": {
      "dependencies": [
        "build"
      ],
      "command": "publint",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "build": {
      "command": "NODE_ENV=production vite build",
      "files": [
        "../../internals/tools/dist/**/*.js",
        "src/**",
        "!src/**/*.test.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.lib.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../../internals/vite:ci",
        "../lint:build",
        {
          "script": "../../internals/tools:build",
          "cascade": false
        }
      ]
    },
    "build:watch": {
      "command": "vite build --watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "dev": {
      "command": "pnpm dlx @modelcontextprotocol/inspector@0.21.1 node ./dist/mcp/index.js",
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint -c ./eslint.config.js --color --cache --cache-location .eslintcache/",
      "files": [
        "src/**/*.ts",
        "eslint.config.js"
      ],
      "output": [],
      "dependencies": [
        "../../internals/eslint:ci"
      ]
    },
    "lint:fix": {
      "command": "eslint -c ./eslint.config.js --fix",
      "dependencies": [
        "../../internals/eslint:ci",
        "../../labs/lint:build"
      ]
    },
    "test": {
      "command": "vitest run",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [],
      "dependencies": [
        "../../testing:build",
        "../../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ]
    },
    "test:watch": {
      "command": "vitest --watch",
      "service": true
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "dist/**/*.js",
        "src/**/*.test.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/unit/**"
      ],
      "dependencies": [
        "../../testing:build",
        "../../internals/vite:ci",
        {
          "script": "build",
          "cascade": false
        }
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}
