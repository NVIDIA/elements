{
  "compilerOptions": {
    "target": "ESNext",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "Node",
    "baseUrl": "./",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "paths": {
      "@nvidia-elements/code": ["./src/index.js"],
      "@nvidia-elements/code/*": ["./src/*"],
      "@nvidia-elements/code/*.js": ["./src/*.js"]
    }
  },
  "include": ["src/**/*.ts"]
}
